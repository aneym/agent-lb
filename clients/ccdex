#!/usr/bin/env python3
from __future__ import annotations

import os
import shutil
import sys
from pathlib import Path


def main() -> None:
    if shutil.which("claude") is None:
        print("ccdex: Claude Code executable 'claude' was not found on PATH", file=sys.stderr)
        raise SystemExit(127)
    launcher = Path(__file__).resolve().with_name("claude-lb-launch")
    environment = os.environ.copy()
    environment["CLAUDE_LB_CODEX_MODE"] = "1"
    os.execve(launcher, [str(launcher), *os.sys.argv[1:]], environment)


if __name__ == "__main__":
    main()
