AGENT_LB_BASE_URL = os.environ.get("CLAUDE_LB_BASE_URL", "http://127.0.0.1:2455").rstrip("/")
CCGPT_MODE = os.environ.get("CLAUDE_LB_CODEX_MODE") == "1"
CCGPT_MODEL = "gpt-5.6-sol"
DEFAULT_CLAUDE_MODEL = "claude-opus-5"
DEFAULT_CLAUDE_EFFORT = "high"
HOP_BY_HOP_HEADERS = {
    "connection",
    "keep-alive",
    "proxy-authenticate",
    "proxy-authorization",
    "te",
    "trailer",
    "transfer-encoding",
    "upgrade",
}
FABLE_SCOPED_WEEKLY_QUOTA_KEY = "anthropic_fable_scoped_weekly"
# The retry budget (~2 minutes with these defaults) must outlast a full
# watchdog-driven LB recovery: an unloaded launchd job is re-bootstrapped
# within ~65s (2 x 30s ticks + startup), so a session mid-request rides the
# outage out instead of surfacing a 502 broken pipe to the agent.
SHIM_CONNECT_RETRIES_DEFAULT = 32
SHIM_CONNECT_BACKOFF_DEFAULT = 0.5
SHIM_CONNECT_BACKOFF_CAP_DEFAULT = 4.0
# Claude Desktop's embedded client opens CONNECT tunnels it never closes;
# without a read timeout each abandoned connection parks a handler thread and
# its fd forever, and the long-lived shared desktop shim exhausts launchd's
# 256-fd soft cap within hours (observed 2026-07-21: 245 leaked loopback fds
# in <5h -> EMFILE 502s). Established blind tunnels are exempt: _splice()
# uses select() and keeps idle tunnels (e.g. the Remote Control websocket)
# open indefinitely; only a socket op wedged this long is torn down.
SHIM_CLIENT_IDLE_TIMEOUT_SECONDS = 600


# ---------------------------------------------------------------------------
# Local intercepting proxy (keeps Remote Control *and* LB routing at once).
# ---------------------------------------------------------------------------
# Claude Code only keeps Remote Control (/rc) enabled when (a) its API endpoint
# is the real api.anthropic.com (its `sCn` first-party check) and (b) the
# *active* login is a full-scope interactive `claude auth login` token carrying
# `user:profile` (its `vx` check). A custom ANTHROPIC_BASE_URL fails (a); the
# unix-socket / CLAUDE_CODE_OAUTH_TOKEN path forces an inference-only token and
# fails (b). So neither of those can route through the LB without killing /rc.
#
# Instead we leave Claude pointed at api.anthropic.com with its keychain login,
# and interpose a local HTTPS proxy. Claude's undici global dispatcher
# (EnvHttpProxyAgent, installed whenever HTTPS_PROXY is set) CONNECT-tunnels
# every request through us. We MITM api.anthropic.com — terminating TLS with a
# locally-minted leaf cert Claude trusts via NODE_EXTRA_CA_CERTS — and forward
# those requests to the LB (which injects the pooled account's auth). Every
# other host (the RC bridge wss://bridge.claudeusercontent.com, telemetry, OAuth
# refresh) is blind-tunnelled untouched, keeping its real end-to-end TLS. Claude
# merges the extra CA with the bundled + system roots (its `H9`/getCACertificates
# path), so trusting our CA never weakens validation of any other host.
#
# The MITM CA is scoped to this process tree only (NODE_EXTRA_CA_CERTS in the
# child env) and is never added to the system trust store.

TLS_DIR = Path.home() / ".agent-lb" / "tls"
CA_CERT = TLS_DIR / "ca.pem"
CA_KEY = TLS_DIR / "ca-key.pem"
LEAF_CERT = TLS_DIR / "leaf.pem"
LEAF_KEY = TLS_DIR / "leaf-key.pem"
CERT_MARKER = TLS_DIR / ".v1"
INTERCEPT_HOSTS = {"api.anthropic.com"}
AGENT_LB_ANTHROPIC_PATHS = frozenset(
    {
        "/health",
        "/v1/messages",
        "/v1/messages/count_tokens",
    }
)


def _routes_to_agent_lb(path: str) -> bool:
    """Return whether an api.anthropic.com request belongs to agent-lb.

    The TLS interception is host-wide because CONNECT happens before the
    client sends an HTTP path. Once decrypted, only the Messages API and the
    installer's health probe belong to agent-lb. Unknown same-host paths are
    first-party Anthropic traffic and default to direct egress so new Claude
    auxiliary APIs do not get swallowed by the local service.
    """
    parsed = urllib.parse.urlsplit(path)
    if parsed.scheme or parsed.netloc:
        return False
    return parsed.path in AGENT_LB_ANTHROPIC_PATHS or (
        parsed.path.endswith("/") and parsed.path[:-1] in AGENT_LB_ANTHROPIC_PATHS
    )


def _run_openssl(args: list[str]) -> None:
    proc = subprocess.run(
        ["openssl", *args],
        stdin=subprocess.DEVNULL,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
    )
    if proc.returncode != 0:
        raise RuntimeError("openssl " + " ".join(args) + " failed:\n" + proc.stdout.decode("utf-8", "replace"))


def ensure_mitm_certs() -> None:
    """Mint (once) a local CA + api.anthropic.com leaf cert under ~/.agent-lb/tls.

    Idempotent: reuses cached certs when present. Shells out to the system
    `openssl` (stdlib can't create x509 certs). Keys are 0600; the dir is 0700.
    """
    if CERT_MARKER.exists() and CA_CERT.exists() and CA_KEY.exists() and LEAF_CERT.exists() and LEAF_KEY.exists():
        return
    if shutil.which("openssl") is None:
        raise RuntimeError("openssl not found on PATH (needed to mint the local MITM cert)")

    TLS_DIR.mkdir(parents=True, exist_ok=True)
    try:
        TLS_DIR.chmod(0o700)
    except OSError:
        pass

    ca_conf = TLS_DIR / "ca.cnf"
    leaf_req_conf = TLS_DIR / "leaf-req.cnf"
    leaf_ext_conf = TLS_DIR / "leaf-ext.cnf"
    leaf_csr = TLS_DIR / "leaf.csr"
    ca_conf.write_text(
        "[req]\n"
        "distinguished_name = dn\n"
        "x509_extensions = v3_ca\n"
        "prompt = no\n"
        "[dn]\n"
        "CN = agent-lb local MITM CA (claude cc)\n"
        "[v3_ca]\n"
        "basicConstraints = critical,CA:TRUE,pathlen:0\n"
        "keyUsage = critical,keyCertSign,cRLSign\n"
        "subjectKeyIdentifier = hash\n"
    )
    leaf_req_conf.write_text("[req]\ndistinguished_name = dn\nprompt = no\n[dn]\nCN = api.anthropic.com\n")
    leaf_ext_conf.write_text(
        "[v3_leaf]\n"
        "basicConstraints = critical,CA:FALSE\n"
        "keyUsage = critical,digitalSignature,keyEncipherment\n"
        "extendedKeyUsage = serverAuth\n"
        "subjectAltName = DNS:api.anthropic.com\n"
    )

    _run_openssl(
        [
            "req",
            "-x509",
            "-new",
            "-nodes",
            "-newkey",
            "rsa:2048",
            "-sha256",
            "-days",
            "3650",
            "-keyout",
            str(CA_KEY),
            "-out",
            str(CA_CERT),
            "-config",
            str(ca_conf),
        ]
    )
    _run_openssl(
        [
            "req",
            "-new",
            "-nodes",
            "-newkey",
            "rsa:2048",
            "-keyout",
            str(LEAF_KEY),
            "-out",
            str(leaf_csr),
            "-config",
            str(leaf_req_conf),
        ]
    )
    _run_openssl(
        [
            "x509",
            "-req",
            "-in",
            str(leaf_csr),
            "-CA",
            str(CA_CERT),
            "-CAkey",
            str(CA_KEY),
            "-CAcreateserial",
            "-out",
            str(LEAF_CERT),
            "-days",
            "3650",
            "-sha256",
            "-extfile",
            str(leaf_ext_conf),
            "-extensions",
            "v3_leaf",
        ]
    )
    for key_file in (CA_KEY, LEAF_KEY):
        try:
            key_file.chmod(0o600)
        except OSError:
            pass
    for scratch in (leaf_csr, ca_conf, leaf_req_conf, leaf_ext_conf):
        try:
            scratch.unlink()
        except OSError:
            pass
    CERT_MARKER.write_text("1\n")


class _LbApiHandler(http.server.BaseHTTPRequestHandler):
    """Serves the MITM'd api.anthropic.com stream, forwarding to the LB.

    Instantiated by hand over an already-TLS-wrapped socket; its config
    (upstream_base_url / session_id / parent_pid / shared) comes from the
    `server` object.
    Mirrors the old shim's forward/stream behaviour: strips hop-by-hop + host
    headers, stamps a launcher-scoped `x-claude-session-id` (while shared mode
    preserves the caller's identity headers), delimits every response by
    connection close, and streams SSE line-by-line.
    """

    protocol_version = "HTTP/1.1"
    timeout = SHIM_CLIENT_IDLE_TIMEOUT_SECONDS

    def log_message(self, format: str, *args: object) -> None:
        return

    def do_GET(self) -> None:
        self._forward()

    def do_POST(self) -> None:
        self._forward()

    def do_PUT(self) -> None:
        self._forward()

    def do_PATCH(self) -> None:
        self._forward()

    def do_DELETE(self) -> None:
        self._forward()

    def do_HEAD(self) -> None:
        self._forward()

    def _forward(self) -> None:
        parent_pid = self.server.parent_pid
        session_id = self.server.session_id
        upstream_base_url = self.server.upstream_base_url
        shared = self.server.shared

        if not shared:
            try:
                assert parent_pid is not None
                os.kill(parent_pid, 0)
            except OSError:
                self.send_error(503, "parent process exited")
                return

        body = None
        if self.command not in {"GET", "HEAD"}:
            try:
                length = int(self.headers.get("content-length", "0"))
            except ValueError:
                length = 0
            body = self.rfile.read(length) if length > 0 else b""

        routes_to_lb = _routes_to_agent_lb(self.path)
        headers = {
            key: value
            for key, value in self.headers.items()
            if key.lower() not in HOP_BY_HOP_HEADERS and key.lower() != "host"
        }
        if routes_to_lb and session_id:
            headers["x-claude-session-id"] = session_id

        if not routes_to_lb:
            self._forward_direct(body, headers)
            return

        try:
            upstream_path = _ccgpt_upstream_path(self.path, body) if self.server.ccgpt_mode else self.path
        except CcgptModelViolation as error:
            message = json.dumps(
                {
                    "type": "error",
                    "error": {
                        "type": "invalid_request_error",
                        "message": str(error),
                    },
                }
            ).encode()
            self.send_response(400)
            self.send_header("content-type", "application/json")
            self.send_header("content-length", str(len(message)))
            self.send_header("connection", "close")
            self.end_headers()
            self.wfile.write(message)
            self.close_connection = True
            return
        request = urllib.request.Request(
            f"{upstream_base_url}{upstream_path}",
            data=body,
            headers=headers,
            method=self.command,
        )
        # Absorb an LB restart or watchdog-driven revival: a refused/reset/
        # broken-pipe connect never produced a response, so retry with bounded
        # backoff before surfacing an error. Real HTTP responses (429/503 with
        # Retry-After) pass straight through.
        connect_retries = max(0, _env_int("CLAUDE_LB_SHIM_CONNECT_RETRIES", SHIM_CONNECT_RETRIES_DEFAULT))
        backoff = max(0.05, _env_float("CLAUDE_LB_SHIM_CONNECT_BACKOFF", SHIM_CONNECT_BACKOFF_DEFAULT))
        backoff_cap = max(backoff, _env_float("CLAUDE_LB_SHIM_CONNECT_BACKOFF_CAP", SHIM_CONNECT_BACKOFF_CAP_DEFAULT))
        attempt = 0
        while True:
            try:
                response = urllib.request.urlopen(request, timeout=600)
            except urllib.error.HTTPError as error:
                response = error
            except Exception as error:
                parent_alive = True
                if not shared:
                    try:
                        assert parent_pid is not None
                        os.kill(parent_pid, 0)
                    except OSError:
                        parent_alive = False
                if attempt < connect_retries and parent_alive and _is_retryable_shim_connect_error(error):
                    time.sleep(min(backoff * (2**attempt), backoff_cap))
                    attempt += 1
                    continue
                self._send_shim_error(error)
                return
            # Copy outside the retry try-block: a client hangup mid-stream is a
            # ConnectionError too, and retrying it would re-send an already
            # processed upstream request. Close the upstream response promptly
            # instead of leaving its socket to the garbage collector.
            try:
                self._copy_response(response)
            finally:
                response.close()
            return

    def _forward_direct(self, body: bytes | None, headers: dict[str, str]) -> None:
        """Forward a first-party auxiliary request without proxy recursion."""
        connection: http.client.HTTPSConnection | None = None
        try:
            connection = http.client.HTTPSConnection(
                "api.anthropic.com",
                443,
                timeout=600,
                context=ssl.create_default_context(),
            )
            connection.request(self.command, self.path, body=body, headers=headers)
            self._copy_response(connection.getresponse())
        except Exception as error:
            self._send_shim_error(error)
        finally:
            if connection is not None:
                connection.close()

    def _send_shim_error(self, error: BaseException) -> None:
        message = json.dumps({"error": {"message": str(error), "code": "claude_lb_shim_error"}}).encode()
        self.send_response(502)
        self.send_header("content-type", "application/json")
        self.send_header("content-length", str(len(message)))
        self.send_header("connection", "close")
        self.end_headers()
        self.wfile.write(message)
        self.close_connection = True

    def _copy_response(self, response: object) -> None:
        status = getattr(response, "status", None) or getattr(response, "code", 502)
        content_type = response.headers.get("content-type", "")
        self.send_response(int(status))
        for key, value in response.headers.items():
            header = key.lower()
            if header not in HOP_BY_HOP_HEADERS and header != "content-length":
                self.send_header(key, value)
        self.send_header("connection", "close")
        self.end_headers()
        if "text/event-stream" in content_type:
            while True:
                line = response.readline()
                if not line:
                    break
                self.wfile.write(line)
                self.wfile.flush()
        else:
            while True:
                chunk = response.read(65536)
                if not chunk:
                    break
                self.wfile.write(chunk)
                self.wfile.flush()
        self.close_connection = True


def _splice(a: socket.socket, b: socket.socket) -> None:
    """Bidirectionally pump bytes between two sockets until either side closes.

    Used for blind CONNECT tunnels (non-intercepted hosts, incl. the long-lived
    Remote Control websocket). The select timeout is only an idle tick — idle
    connections are kept open, never torn down.
    """
    ends = (a, b)
    try:
        while True:
            readable, _, errored = select.select(ends, [], ends, 300)
            if errored:
                break
            if not readable:
                continue
            for src in readable:
                dst = b if src is a else a
                try:
                    data = src.recv(65536)
                except OSError:
                    return
                if not data:
                    return
                try:
                    dst.sendall(data)
                except OSError:
                    return
    finally:
        for sock in ends:
            try:
                sock.close()
            except OSError:
                pass


class _ProxyHandler(http.server.BaseHTTPRequestHandler):
    """Front HTTPS proxy: MITMs INTERCEPT_HOSTS, blind-tunnels everything else."""

    protocol_version = "HTTP/1.1"
    timeout = SHIM_CLIENT_IDLE_TIMEOUT_SECONDS

    def log_message(self, format: str, *args: object) -> None:
        return

    def do_CONNECT(self) -> None:
        host, _, port_text = self.path.partition(":")
        try:
            port = int(port_text) if port_text else 443
        except ValueError:
            port = 443
        # Everything is handled inline; never let the base handler reuse the
        # raw socket after we hijack it for TLS or a tunnel.
        self.close_connection = True
        if host in INTERCEPT_HOSTS:
            self._mitm()
        else:
            self._tunnel(host, port)

    def _mitm(self) -> None:
        # The client (undici) waits for this 200 before sending its ClientHello,
        # so nothing is buffered on self.rfile yet.
        try:
            self.connection.sendall(b"HTTP/1.1 200 Connection Established\r\n\r\n")
        except OSError:
            return
        # Dup the fd so the TLS socket owns an independent handle; the base
        # handler's finish() can then close self.connection without racing us.
        try:
            raw = socket.socket(
                self.connection.family,
                self.connection.type,
                fileno=os.dup(self.connection.fileno()),
            )
        except OSError:
            return
        # The handler timeout put the shared open file description in
        # non-blocking mode, and socket(fileno=...) adopts the fd's actual
        # blocking state — without an explicit timeout the TLS handshake
        # would fail (and could otherwise hang forever on a silent client).
        raw.settimeout(SHIM_CLIENT_IDLE_TIMEOUT_SECONDS)
        try:
            tls = self.server.tls_context.wrap_socket(raw, server_side=True)
        except (OSError, ValueError):
            try:
                raw.close()
            except OSError:
                pass
            return
        try:
            # Drives setup()->handle()->finish() synchronously over the TLS
            # socket, forwarding to the LB. Config is read from self.server.
            _LbApiHandler(tls, ("127.0.0.1", 0), self.server)
        except OSError:
            pass
        finally:
            try:
                tls.close()
            except OSError:
                pass

    def _tunnel(self, host: str, port: int) -> None:
        try:
            upstream = socket.create_connection((host, port), timeout=20)
        except OSError:
            try:
                self.connection.sendall(b"HTTP/1.1 502 Bad Gateway\r\n\r\n")
            except OSError:
                pass
            return
        try:
            self.connection.sendall(b"HTTP/1.1 200 Connection Established\r\n\r\n")
        except OSError:
            try:
                upstream.close()
            except OSError:
                pass
            return
        _splice(self.connection, upstream)


class _ThreadingProxyServer(socketserver.ThreadingMixIn, http.server.HTTPServer):
    """Threaded HTTPS proxy on an ephemeral loopback port."""

    daemon_threads = True
    allow_reuse_address = True

    def handle_error(self, request: object, client_address: object) -> None:
        # Proxy teardown races (a client hanging up mid-tunnel) raise benign
        # socket errors; suppress the default traceback dump to stderr.
        return


def proxy_ready_path(session_id: str) -> Path:
    shim_dir = Path.home() / ".agent-lb" / "shims"
    shim_dir.mkdir(parents=True, exist_ok=True)
    try:
        shim_dir.chmod(0o700)
    except OSError:
        pass
    return shim_dir / f"{session_id}.proxy"


def _raise_fd_soft_limit() -> None:
    """Launchd starts children with a 256-fd soft cap; a proxy shim serving a
    whole desktop session (or machine) needs real headroom while idle-reaping
    catches up, so lift the soft limit toward macOS's OPEN_MAX. Best-effort:
    a refusal must never stop the shim from serving."""
    try:
        soft, hard = resource.getrlimit(resource.RLIMIT_NOFILE)
        target = 10240 if hard == resource.RLIM_INFINITY else min(hard, 10240)
        if soft < target:
            resource.setrlimit(resource.RLIMIT_NOFILE, (target, hard))
    except (OSError, ValueError):
        pass


def run_lb_proxy(
    ready_path: str,
    session_id: str,
    parent_pid: int | None,
    upstream_base_url: str,
    listen_port: int = 0,
    *,
    shared: bool = False,
) -> None:
    if not shared and parent_pid is None:
        raise ValueError("parent_pid is required for a launcher-scoped proxy")
    _raise_fd_soft_limit()
    ensure_mitm_certs()
    tls_context = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
    tls_context.load_cert_chain(certfile=str(LEAF_CERT), keyfile=str(LEAF_KEY))

    server = _ThreadingProxyServer(("127.0.0.1", listen_port), _ProxyHandler)
    server.tls_context = tls_context
    server.session_id = session_id
    server.parent_pid = parent_pid
    server.shared = shared
    server.ccgpt_mode = CCGPT_MODE and not shared
    server.upstream_base_url = upstream_base_url.rstrip("/")
    port = server.server_address[1]

    ready = Path(ready_path)
    tmp = ready.with_name(ready.name + ".tmp")
    tmp.write_text(f"{port}\n")
    os.replace(tmp, ready)

    def stop_when_parent_exits() -> None:
        assert parent_pid is not None
        while True:
            try:
                os.kill(parent_pid, 0)
            except OSError:
                server.shutdown()
                return
            time.sleep(2.0)

    if not shared:
        threading.Thread(target=stop_when_parent_exits, daemon=True).start()
    try:
        server.serve_forever()
    finally:
        try:
            ready.unlink()
        except OSError:
            pass


def _proxy_port_ready(port: int, timeout: float = 0.4) -> bool:
    try:
        with socket.create_connection(("127.0.0.1", port), timeout=timeout):
            return True
    except OSError:
        return False


def start_lb_proxy(session_id: str) -> str:
    ready = proxy_ready_path(session_id)
    try:
        ready.unlink()
    except OSError:
        pass
    _spawn_lb_proxy(ready, session_id, os.getpid(), AGENT_LB_BASE_URL)
    deadline = time.monotonic() + _env_float("CLAUDE_LB_SHIM_START_TIMEOUT", 12.0)
    while time.monotonic() < deadline:
        try:
            text = ready.read_text().strip()
        except OSError:
            text = ""
        if text:
            try:
                port = int(text)
            except ValueError:
                port = 0
            if port and _proxy_port_ready(port):
                return f"http://127.0.0.1:{port}"
        time.sleep(0.05)
    raise RuntimeError("Claude LB intercepting proxy did not start")


def _spawn_lb_proxy(ready: Path, session_id: str, parent_pid: int, upstream_base_url: str) -> None:
    command = [
        sys.executable,
        str(Path(__file__).resolve()),
        "--lb-proxy",
        str(ready),
        session_id,
        str(parent_pid),
        upstream_base_url,
    ]
    subprocess.Popen(
        command,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def lb_enabled() -> bool:
    return os.environ.get("CLAUDE_LB_DISABLE") != "1"


def bypass_anthropic_proxy() -> None:
    """Keep plain-Claude fallback out of a configured shared desktop proxy."""
    for name in ("NO_PROXY", "no_proxy"):
        exclusions = [entry.strip() for entry in os.environ.get(name, "").split(",") if entry.strip()]
        if not any(entry.lower() == "api.anthropic.com" for entry in exclusions):
            exclusions.append("api.anthropic.com")
        os.environ[name] = ",".join(exclusions)


def lb_json(path: str, *, timeout: float = 2.5, base_url: str | None = None) -> dict:
    request = urllib.request.Request(f"{base_url or AGENT_LB_BASE_URL}{path}", headers={"accept": "application/json"})
    with urllib.request.urlopen(request, timeout=timeout) as response:
        body = response.read().decode("utf-8")
    return json.loads(body) if body else {}


def lb_post_json(path: str, payload: dict[str, str], *, timeout: float = 4.0, base_url: str | None = None) -> dict:
    body = json.dumps(payload).encode("utf-8")
    request = urllib.request.Request(
        f"{base_url or AGENT_LB_BASE_URL}{path}",
        data=body,
        headers={"accept": "application/json", "content-type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(request, timeout=timeout) as response:
        response_body = response.read().decode("utf-8")
    return json.loads(response_body) if response_body else {}


def _env_float(name: str, default: float) -> float:
    try:
        return float(os.environ.get(name, "") or default)
    except (TypeError, ValueError):
        return default


def _env_int(name: str, default: int) -> int:
    try:
        return int(os.environ.get(name, "") or default)
    except (TypeError, ValueError):
        return default


def _is_retryable_shim_connect_error(error: BaseException) -> bool:
    """True for connection-level failures that mean the request never reached a
    live LB (e.g. connection refused/reset while the service restarts).

    These are safe to retry because no response was produced and the upstream
    did not process the request. A real HTTP response (HTTPError) is never
    retried — its status, including 429/503 with Retry-After, is passed straight
    through to the agent. Read timeouts are excluded too, since the request may
    already be in flight and re-sending could double-process it.
    """
    if isinstance(error, urllib.error.HTTPError):
        return False
    reason = getattr(error, "reason", None)
    return isinstance(error, ConnectionError) or isinstance(reason, ConnectionError)


def _is_unreachable_health_error(error: BaseException) -> bool:
    if isinstance(error, urllib.error.HTTPError):
        return False
    reason = getattr(error, "reason", error)
    if isinstance(reason, ConnectionError):
        return True
    return isinstance(reason, OSError) and reason.errno in {
        errno.ECONNREFUSED,
        errno.EHOSTUNREACH,
        errno.ENETDOWN,
        errno.ENETUNREACH,
    }


def _probe_health_at(base_url: str, *, retries: int, timeout: float, gap: float) -> tuple[bool, str, bool]:
    """Probe /health/ready at base_url, retrying briefly so a transient LB restart or
    tailscale blip does not force the whole session onto plain-claude fallback.

    The healthy path returns on the first probe (tens of ms); only failures pay
    the retry/backoff cost.
    """
    last_error = "no response"
    last_error_unreachable = False
    for attempt in range(retries):
        try:
            lb_json("/health/ready", timeout=timeout, base_url=base_url)
            return True, "", False
        except (OSError, urllib.error.URLError, TimeoutError, json.JSONDecodeError) as error:
            last_error = str(error) or error.__class__.__name__
            last_error_unreachable = _is_unreachable_health_error(error)
            if attempt + 1 < retries:
                time.sleep(gap)
    return False, last_error, last_error_unreachable


def _local_launchd_job_loaded() -> bool:
    label = os.environ.get("CLAUDE_LB_LAUNCHD_LABEL") or "com.aneyman.agent-lb"
    try:
        result = subprocess.run(
            ["launchctl", "print", f"gui/{os.getuid()}/{label}"],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=1.0,
            check=False,
        )
    except (AttributeError, OSError, subprocess.TimeoutExpired):
        return False
    return result.returncode == 0


def _wait_for_local_startup(base_url: str, *, probe_timeout: float) -> bool:
    grace_seconds = max(0.0, _env_float("CLAUDE_LB_STARTUP_GRACE_SECONDS", 90.0))
    if grace_seconds == 0 or not _local_launchd_job_loaded():
        return False

    print(
        f"cc: agent-lb is starting — waiting up to {grace_seconds:g}s for /health/ready ...",
        file=sys.stderr,
    )
    deadline = time.monotonic() + grace_seconds
    while True:
        remaining = deadline - time.monotonic()
        if remaining <= 0:
            return False
        time.sleep(min(1.0, remaining))
        remaining = deadline - time.monotonic()
        if remaining <= 0:
            return False
        ready, _, _ = _probe_health_at(
            base_url,
            retries=1,
            timeout=min(probe_timeout, remaining),
            gap=0.0,
        )
        if ready:
            print("cc: agent-lb is ready — continuing with local LB", file=sys.stderr)
            return True


def _lb_candidates() -> list[tuple[str, str]]:
    """Ordered (label, url) candidates: local first, then remote, deduplicated.

    CLAUDE_LB_LOCAL_PREFER=0 drops the local candidate entirely, restoring the
    pre-federation single-URL behavior driven solely by CLAUDE_LB_BASE_URL.
    """
    # Empty-string env values count as unset (an empty base URL crashes urllib).
    local_url = (os.environ.get("CLAUDE_LB_LOCAL_URL") or "http://127.0.0.1:2455").rstrip("/")
    remote_url = (os.environ.get("CLAUDE_LB_BASE_URL") or "http://127.0.0.1:2455").rstrip("/")
    prefer_local = os.environ.get("CLAUDE_LB_LOCAL_PREFER") != "0"
    prefer_remote = os.environ.get("CLAUDE_LB_PREFER_REMOTE") == "1"

    candidates: list[tuple[str, str]] = []
    if prefer_remote and remote_url != local_url:
        candidates.append(("remote", remote_url))
    if prefer_local:
        candidates.append(("local", local_url))
    if remote_url != local_url and all(url != remote_url for _, url in candidates):
        candidates.append(("remote", remote_url))
    if not candidates:
        candidates.append(("remote", remote_url))
    return candidates


def arg_value(argv: list[str], *names: str) -> str | None:
    for index, value in enumerate(argv):
        for name in names:
            if value == name and index + 1 < len(argv):
                return argv[index + 1]
            prefix = f"{name}="
            if value.startswith(prefix):
                return value[len(prefix) :]
    return None


def requested_model(argv: list[str]) -> str:
    return arg_value(argv, "--model", "-m") or os.environ.get("ANTHROPIC_MODEL") or DEFAULT_CLAUDE_MODEL


def requested_effort(argv: list[str]) -> str:
    return arg_value(argv, "--effort") or os.environ.get("CC_EFFORT_LEVEL") or DEFAULT_CLAUDE_EFFORT


def anthropic_quota_key(model: str, effort: str) -> tuple[str, str]:
    normalized_model = model.lower()
    normalized_effort = effort.lower()
    if "haiku" in normalized_model:
        return "anthropic_standard", "standard"
    if normalized_effort not in {"", "none", "off"}:
        return "anthropic_top_thinking", "top-thinking"
    return "anthropic_top", "top-model"


def short_account_name(account: dict) -> str:
    return (
        account.get("alias")
        or account.get("displayName")
        or account.get("email")
        or str(account.get("accountId", "unknown"))[:8]
    )


def number(value: object, default: float = 0.0) -> float:
    if isinstance(value, (int, float)):
        return float(value)
    try:
        return float(str(value))
    except (TypeError, ValueError):
        return default


def reset_label(reset_at: object) -> str:
    reset = number(reset_at, 0.0)
    if reset <= 0:
        return "reset unknown"
    remaining = max(0, int(reset - time.time()))
    if remaining < 90:
        return "resets <2m"
    if remaining < 3600:
        return f"resets {round(remaining / 60)}m"
    return f"resets {round(remaining / 3600)}h"


def _stderr_color() -> bool:
    return sys.stderr.isatty() and not os.environ.get("NO_COLOR")


def _c(text: str, code: str) -> str:
    return f"\033[{code}m{text}\033[0m" if _stderr_color() else text


def _pct_left(remaining: float) -> str:
    label = f"{remaining:.0f}%"
    if remaining >= 50:
        return _c(label, "32")
    if remaining >= 20:
        return _c(label, "33")
    return _c(label, "31")


def fable_remaining_percent(account: dict) -> float | None:
    for quota in account.get("additionalQuotas") or []:
        if quota.get("quotaKey") != FABLE_SCOPED_WEEKLY_QUOTA_KEY:
            continue
        window = quota.get("primaryWindow")
        if not isinstance(window, dict) or window.get("usedPercent") is None:
            return None
        used_percent = number(window.get("usedPercent"), -1.0)
        if used_percent < 0:
            return None
        return max(0.0, min(100.0, 100.0 - used_percent))
    return None


def fable_availability_label(account: dict) -> str:
    eligible = account.get("fableEligible")
    remaining = fable_remaining_percent(account)
    if remaining is not None:
        remaining_label = _pct_left(remaining)
        if eligible is False:
            return f"fable out ({remaining_label} left)"
        return f"fable {remaining_label} left"
    if eligible is True:
        return f"fable {_c('available', '32')}"
    if eligible is False:
        return f"fable {_c('out', '31')}"
    return ""


def quota_window(account: dict, quota_key: str) -> dict:
    for quota in account.get("additionalQuotas") or []:
        if quota.get("quotaKey") == quota_key:
            return quota.get("primaryWindow") or {}
    return {}


def account_pressure(account: dict, quota_key: str) -> tuple[bool, float, float, float, str, str]:
    window = quota_window(account, quota_key)
    quota_used_percent = number(window.get("usedPercent"), 0.0)
    reset_at = number(window.get("resetAt"), 0.0)
    blocked = quota_used_percent >= 100.0 and reset_at > time.time()

    usage = account.get("usage") or {}
    primary_remaining = number(
        usage.get("primaryRemainingPercent", account.get("remainingCreditsPrimary")),
        100.0,
    )
    weekly_remaining = number(
        usage.get("secondaryRemainingPercent", account.get("remainingCreditsSecondary")),
        100.0,
    )
    primary_used = max(0.0, min(100.0, 100.0 - primary_remaining))
    weekly_used = max(0.0, min(100.0, 100.0 - weekly_remaining))
    quota_name = quota_key.replace("anthropic_", "").replace("_", "-")
    quota_left = max(0.0, min(100.0, 100.0 - quota_used_percent))
    parts = [
        f"left: {quota_name} {_pct_left(quota_left)}",
        f"5h {_pct_left(100.0 - primary_used)}",
        f"weekly {_pct_left(100.0 - weekly_used)}",
    ]
    fable_label = fable_availability_label(account)
    if fable_label:
        parts.append(fable_label)
    reason = " · ".join(parts)
    if blocked:
        reason = f"{reason} · {_c(reset_label(reset_at), '31')}"
    return blocked, primary_used, weekly_used, quota_used_percent, short_account_name(account), reason


def _error_message_from_body(body: str) -> str:
    text = body.strip()
    if not text:
        return "Request failed"
    try:
        payload = json.loads(text)
    except json.JSONDecodeError:
        return text
    if not isinstance(payload, dict):
        return text

    error = payload.get("error")
    if isinstance(error, dict):
        message = error.get("message")
        if isinstance(message, str) and message.strip():
            return message.strip()

    message = payload.get("message")
    if isinstance(message, str) and message.strip():
        return message.strip()
    return text


def _prettify_anthropic_selection_error(message: str) -> str:
    marker = "Anthropic account"
    status_marker = "; statuses: "
    if marker not in message or "none are selectable" not in message or status_marker not in message:
        return message

    count_text = message.split(marker, 1)[0].strip().split()[-1:]
    count = count_text[0] if count_text else ""
    status_summary = message.split(status_marker, 1)[1].split(".", 1)[0].strip()
    if not count or not status_summary:
        return message

    if status_summary == f"rate_limited={count}":
        summary = f"all Claude accounts are rate-limited ({count} accounts)"
    else:
        summary = f"Claude accounts are all at limit or unavailable ({count} accounts; {status_summary})"

    quota_detail = ""
    quota_marker = "Model quota: "
    if quota_marker in message:
        raw_quota_detail = message.split(quota_marker, 1)[1]
        raw_quota_detail = raw_quota_detail.split(" OpenAI accounts", 1)[0]
        raw_quota_detail = raw_quota_detail.split(" Limits reset", 1)[0].strip()
        if raw_quota_detail.endswith("."):
            raw_quota_detail = raw_quota_detail[:-1]
        if raw_quota_detail:
            quota_detail = f" Model quota: {raw_quota_detail}."

    suffix = ""
    if "OpenAI accounts are not eligible for Claude routing" in message:
        suffix = " OpenAI accounts cannot serve Claude."
    return f"{summary}.{quota_detail}{suffix}"


def format_lb_pick_error(body: str) -> str:
    return _prettify_anthropic_selection_error(_error_message_from_body(body))


WAIT_BUFFER_SECONDS = 20
RESUME_MAX_ATTEMPTS = 5


def _epoch_from_iso(value: str) -> int | None:
    normalized = value.strip()
    if normalized.endswith("Z"):
        normalized = f"{normalized[:-1]}+00:00"
    try:
        return int(datetime.fromisoformat(normalized).timestamp())
    except ValueError:
        return None


def retry_at_from_error_body(body: str) -> int | None:
    """Extract the LB's advertised limit-reset epoch from an error envelope."""
    try:
        payload = json.loads(body)
    except json.JSONDecodeError:
        return None
    error = payload.get("error") if isinstance(payload, dict) else None
    if not isinstance(error, dict):
        return None
    retry_at = error.get("retryAt")
    if isinstance(retry_at, str):
        epoch = _epoch_from_iso(retry_at)
        if epoch is not None:
            return epoch
    retry_after = error.get("retryAfterSeconds")
    if isinstance(retry_after, (int, float)) and retry_after >= 0:
        return int(time.time() + retry_after)
    return None


def wait_mode() -> str:
    value = (os.environ.get("CLAUDE_LB_WAIT_FOR_LIMIT") or "auto").strip().lower()
    return value if value in {"auto", "always", "never"} else "auto"


def wait_max_seconds() -> int:
    try:
        return max(0, int(os.environ.get("CLAUDE_LB_WAIT_MAX_SECONDS", "21600")))
    except ValueError:
        return 21600


def should_wait_for_reset(retry_at: int | None, deadline: float) -> bool:
    if retry_at is None or wait_mode() == "never":
        return False
    return retry_at + WAIT_BUFFER_SECONDS <= deadline


def wait_until_reset(retry_at: int, reason: str) -> None:
    target = retry_at + WAIT_BUFFER_SECONDS
    local_label = time.strftime("%H:%M:%S", time.localtime(target))
    print(
        f"cc: {reason} Waiting until {_c(local_label, '1;33')} for limits to reset (Ctrl-C to abort).",
        file=sys.stderr,
    )
    while True:
        remaining = target - time.time()
        if remaining <= 0:
            return
        time.sleep(min(remaining, 30.0))


def claim_session_route(
    session_id: str, model: str, quota_key: str, base_url: str, *, timeout: float | None = None
) -> tuple[dict | None, str, int | None]:
    """Claim a sticky route at base_url. Returns (claim, error_message, retry_at_epoch)."""
    try:
        claim = lb_post_json(
            "/api/anthropic/session-route",
            {"sessionId": session_id, "model": model, "quotaKey": quota_key},
            timeout=timeout if timeout is not None else _env_float("CLAUDE_LB_CLAIM_TIMEOUT", 5.0),
            base_url=base_url,
        )
        return claim, "", None
    except urllib.error.HTTPError as error:
        body = error.read().decode("utf-8", errors="replace")
        return None, format_lb_pick_error(body), retry_at_from_error_body(body)
    except (OSError, urllib.error.URLError, TimeoutError, json.JSONDecodeError) as error:
        return None, str(error), None


def _claim_at_endpoint(
    base_url: str,
    session_id: str,
    model: str,
    quota_key: str,
    deadline: float,
    request_timeout: float | None = None,
) -> tuple[dict | None, str]:
    """Claim a route at base_url, waiting out advertised limit resets in place
    (same account pool) up to deadline. Returns (claim, "") on success, or
    (None, error_message) once retryable waiting is exhausted or the failure
    isn't retryable — the caller decides whether to fall through to the next
    candidate endpoint.
    """
    while True:
        claim, error_message, retry_at = claim_session_route(
            session_id,
            model,
            quota_key,
            base_url,
            timeout=request_timeout,
        )
        if claim is not None:
            return claim, ""
        if not should_wait_for_reset(retry_at, deadline):
            return None, error_message
        try:
            wait_until_reset(retry_at, error_message)
        except KeyboardInterrupt:
            print("cc: aborted while waiting for limits to reset", file=sys.stderr)
            sys.exit(130)


def print_lb_banner(argv: list[str], session_id: str) -> bool:
    global AGENT_LB_BASE_URL
    model = requested_model(argv)
    effort = requested_effort(argv)
    quota_key, quota_label = anthropic_quota_key(model, effort)
    model_label = model.replace("claude-", "")

    # A successful route claim proves both endpoint reachability and account
    # availability. Claim each candidate directly so startup does not pay for a
    # redundant health round trip first.
    timeout = _env_float("CLAUDE_LB_HEALTH_TIMEOUT", 3.0)
    local_timeout = min(2.0, timeout)
    deadline = time.time() + wait_max_seconds()

    claim_failures: list[str] = []
    selected_url = ""
    selected_label = ""
    claim: dict | None = None
    for label, url in _lb_candidates():
        request_timeout = local_timeout if label == "local" else _env_float("CLAUDE_LB_CLAIM_TIMEOUT", 5.0)
        claim, claim_error = _claim_at_endpoint(
            url,
            session_id,
            model,
            quota_key,
            deadline,
            request_timeout=request_timeout,
        )
        if claim is not None:
            selected_url, selected_label = url, label
            break
        claim_failures.append(f"{label} ({url}): {claim_error}")

    if claim is None:
        if claim_failures:
            print(
                f"cc: Claude LB could not pick an account for {model_label}/{quota_label}: "
                + "; ".join(claim_failures),
                file=sys.stderr,
            )
        else:
            print("cc: Claude LB unavailable (no candidates configured)", file=sys.stderr)
        return False

    AGENT_LB_BASE_URL = selected_url
    endpoint_note = f"via {urllib.parse.urlsplit(selected_url).netloc or selected_url}"
    if selected_label == "local":
        endpoint_note += " (local)"

    selected_account_id = str(claim.get("accountId") or "")

    try:
        # Banner enrichment only — the route is already claimed. Keep this off the
        # startup critical path: cap the wait and fall back to the claim-based banner.
        payload = lb_json("/api/accounts", timeout=_env_float("CLAUDE_LB_BANNER_TIMEOUT", 1.5))
    except (OSError, urllib.error.URLError, TimeoutError, json.JSONDecodeError):
        account_label = claim.get("alias") or claim.get("email") or selected_account_id[:8]
        print(
            f"cc: {_c('Claude LB', '1;36')} → {_c(account_label, '1')} · {model_label}/{quota_label} · "
            f"proxy-claimed session route {_c('· OAuth/Max · sticky+failover', '2')} {_c(endpoint_note, '2')}",
            file=sys.stderr,
        )
        return True

    accounts = payload.get("accounts") or []
    anthropic = [
        account
        for account in accounts
        if account.get("provider") == "anthropic" and str(account.get("status", "")).lower() == "active"
    ]
    if not anthropic:
        account_label = claim.get("alias") or claim.get("email") or selected_account_id[:8]
        print(
            f"cc: {_c('Claude LB', '1;36')} → {_c(account_label, '1')} · {model_label}/{quota_label} · "
            f"proxy-claimed session route {_c('· OAuth/Max · sticky+failover', '2')} {_c(endpoint_note, '2')}",
            file=sys.stderr,
        )
        return True

    selected_account: dict | None = None
    for account in anthropic:
        if str(account.get("accountId") or "") == selected_account_id:
            selected_account = account
            break
    selected = selected_account or {
        "accountId": selected_account_id,
        "email": claim.get("email"),
        "alias": claim.get("alias"),
    }
    _, _, _, _, _, reason = account_pressure(selected, quota_key)
    print(
        f"cc: {_c('Claude LB', '1;36')} → {_c(short_account_name(selected), '1')} · {model_label} · "
        f"{reason} {_c('· OAuth/Max · sticky+failover', '2')} {_c(endpoint_note, '2')}",
        file=sys.stderr,
    )
    return True


def prepare_interactive_endpoint() -> bool:
    """Select a ready endpoint without blocking Claude's UI on account selection.

    The proxy request carries the session id, so the server performs the same
    sticky account selection when the user sends their first message. Eager
    claiming remains in place for headless runs, where reset waiting and an
    immediately actionable failure are part of the command contract.
    """
    global AGENT_LB_BASE_URL
    failures: list[str] = []
    # 3.0s (was 1.5s, was 0.35s): the front proxy holds and retries refused
    # upstream connects every 500ms during short LB stalls, and on a heavily
    # loaded host (observed 2026-07-17: load avg 260, /health/ready spiking to
    # ~1.7s) every 1.5s attempt in the retry cycle timed out even though the LB
    # was alive. The healthy path still returns in tens of ms; only an
    # up-but-slow server pays this budget, which is exactly when waiting beats
    # falling back to plain claude.
    local_timeout = _env_float("CLAUDE_LB_LOCAL_READY_TIMEOUT", 3.0)
    remote_timeout = _env_float("CLAUDE_LB_REMOTE_READY_TIMEOUT", 3.0)
    for label, url in _lb_candidates():
        # 3 attempts spaced 1s apart: the LB event loop stalls in short bursts
        # under heavy streaming load, and a single 0.35s probe landing inside
        # one burst used to force the whole session onto plain-claude fallback
        # (2026-07-16). The healthy path still returns on the first probe.
        ready, error, unreachable = _probe_health_at(
            url,
            retries=3,
            timeout=local_timeout if label == "local" else remote_timeout,
            gap=1.0,
        )
        if label == "local" and not ready and unreachable:
            ready = _wait_for_local_startup(url, probe_timeout=local_timeout)
        if not ready:
            failures.append(f"{label} ({url}): {error}")
            continue
        AGENT_LB_BASE_URL = url
        endpoint = urllib.parse.urlsplit(url).netloc or url
        suffix = " (local)" if label == "local" else ""
        print(
            f"cc: {_c('Claude LB', '1;36')} · sticky account selected on first message "
            f"{_c(f'via {endpoint}{suffix}', '2')}",
            file=sys.stderr,
        )
        return True
    print("cc: agent-lb unavailable (" + "; ".join(failures) + ")", file=sys.stderr)
    return False


def prepare_ccgpt_endpoint() -> bool:
    """Select a compatible LB endpoint without claiming an Anthropic account."""
    global AGENT_LB_BASE_URL
    failures: list[str] = []
    timeout = _env_float("CLAUDE_LB_HEALTH_TIMEOUT", 3.0)
    for label, url in _lb_candidates():
        compatible, capability_error = _probe_ccgpt_at(
            url,
            timeout=min(2.0, timeout) if label == "local" else timeout,
        )
        if not compatible:
            failures.append(f"{label} ({url}): {capability_error}")
            continue
        AGENT_LB_BASE_URL = url
        endpoint = urllib.parse.urlsplit(url).netloc or url
        suffix = " (local)" if label == "local" else ""
        print(
            f"ccgpt: {_c('Claude Code + Codex', '1;36')} · {CCGPT_MODEL}/high · "
            f"{'bypass perms' if not _has_permission_option(sys.argv[1:]) else 'custom perms'} · "
            f"requested priority {_c(f'via {endpoint}{suffix}', '2')}",
            file=sys.stderr,
        )
        return True
    print("ccgpt: agent-lb unavailable (" + "; ".join(failures) + ")", file=sys.stderr)
    return False


def _probe_ccgpt_at(base_url: str, *, timeout: float) -> tuple[bool, str]:
    payload = json.dumps({"model": CCGPT_MODEL, "messages": []}).encode()
    request = urllib.request.Request(
        f"{base_url}/v1/ccgpt/messages/count_tokens",
        data=payload,
        headers={"content-type": "application/json", "accept": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(request, timeout=timeout) as response:
            body = json.loads(response.read().decode("utf-8") or "{}")
    except (OSError, urllib.error.URLError, TimeoutError, json.JSONDecodeError) as error:
        return False, f"ccgpt compatibility probe failed: {error}"
    count = body.get("input_tokens") if isinstance(body, dict) else None
    if not isinstance(count, int):
        return False, "ccgpt compatibility probe returned an invalid response"
    try:
        accounts = lb_json("/api/accounts", timeout=timeout, base_url=base_url).get("accounts") or []
    except (OSError, urllib.error.URLError, TimeoutError, json.JSONDecodeError) as error:
        return False, f"ccgpt account-pool probe failed: {error}"
    if not any(
        account.get("provider") == "openai"
        and str(account.get("status", "")).lower() == "active"
        and str(account.get("routingPolicy", "normal")).lower() not in {"paused", "disabled"}
        for account in accounts
    ):
        return False, "no active OpenAI accounts"
    return True, ""


class CcgptModelViolation(ValueError):
    pass


def _ccgpt_upstream_path(path: str, body: bytes | None = None) -> str:
    if not CCGPT_MODE:
        return path
    parsed = urllib.parse.urlsplit(path)
    if parsed.scheme or parsed.netloc:
        return path
    exact_paths = {
        "/v1/messages",
        "/v1/messages/",
        "/v1/messages/count_tokens",
        "/v1/messages/count_tokens/",
    }
    if parsed.path not in exact_paths:
        return path
    normalized = parsed.path[:-1] if parsed.path.endswith("/") else parsed.path
    suffix = path[len(parsed.path) :]
    trailing_slash = "/" if parsed.path.endswith("/") else ""
    if normalized == "/v1/messages/count_tokens":
        return f"/v1/ccgpt/messages/count_tokens{trailing_slash}{suffix}"
    requested = _ccgpt_request_model(body)
    if requested != CCGPT_MODEL:
        label = requested or "missing model"
        raise CcgptModelViolation(
            f"CCGPT only permits its canonical GPT model; rejected Messages request for {label}"
        )
    return f"/v1/ccgpt/messages{trailing_slash}{suffix}"


def _ccgpt_request_model(body: bytes | None) -> str | None:
    if not body:
        return None
    try:
        payload = json.loads(body)
    except (UnicodeDecodeError, json.JSONDecodeError):
        return None
    model = payload.get("model") if isinstance(payload, dict) else None
    return model if isinstance(model, str) else None


def _without_option(argv: list[str], option: str) -> list[str]:
    cleaned: list[str] = []
    skip_next = False
    for argument in argv:
        if skip_next:
            skip_next = False
            continue
        if argument == option:
            skip_next = True
            continue
        if argument.startswith(option + "="):
            continue
        cleaned.append(argument)
    return cleaned


def build_command(argv: list[str]) -> list[str]:
    command = ["claude"]
    if CCGPT_MODE:
        argv = _without_option(_without_option(argv, "--model"), "--effort")
        command.extend(["--model", CCGPT_MODEL, "--effort", "high"])
    else:
        if arg_value(argv, "--model", "-m") is None and not os.environ.get("ANTHROPIC_MODEL"):
            command.extend(["--model", DEFAULT_CLAUDE_MODEL])
        if arg_value(argv, "--effort") is None:
            command.extend(["--effort", os.environ.get("CC_EFFORT_LEVEL") or DEFAULT_CLAUDE_EFFORT])
    permission_mode = None if CCGPT_MODE else os.environ.get("CC_PERMISSION_MODE")
    if CCGPT_MODE and not _has_permission_option(argv):
        permission_mode = "bypassPermissions"
    if permission_mode:
        command.extend(["--permission-mode", permission_mode])
    command.extend(argv)
    return command


def _has_permission_option(argv: list[str]) -> bool:
    return any(
        argument == "--permission-mode"
        or argument.startswith("--permission-mode=")
        or argument == "--dangerously-skip-permissions"
        for argument in argv
    )


def headless_invocation(argv: list[str]) -> bool:
    return "-p" in argv or "--print" in argv


def derive_session_id(argv: list[str]) -> str:
    """Session id for LB sticky routing.

    An explicit CLAUDE_LB_SESSION_ID always wins. Headless (`-p`/`--print`) runs
    without one derive a stable id from the working directory so a loop of
    `claude -p` turns keeps one sticky account and its warm prompt cache instead
    of scattering a fresh `cc-<pid>-<epoch>` route each turn. Interactive runs
    keep the per-process id.
    """
    explicit = os.environ.get("CLAUDE_LB_SESSION_ID")
    if explicit:
        return explicit
    if headless_invocation(argv):
        digest = hashlib.sha256(os.getcwd().encode()).hexdigest()[:12]
        return f"cc-headless-{digest}"
    return f"cc-{os.getpid()}-{int(time.time())}"


def auto_resume_enabled() -> bool:
    value = (os.environ.get("CLAUDE_LB_AUTO_RESUME") or "1").strip().lower()
    return value not in {"0", "never", "off", "false"}


def build_resume_command(argv: list[str], claude_session_id: str) -> list[str]:
    command = ["claude"]
    effort = os.environ.get("CC_EFFORT_LEVEL")
    if effort:
        command.extend(["--effort", effort])
    permission_mode = os.environ.get("CC_PERMISSION_MODE")
    if permission_mode:
        command.extend(["--permission-mode", permission_mode])
    for flag in ("--model", "--output-format"):
        value = arg_value(argv, flag)
        if value:
            command.extend([flag, value])
    command.extend(
        [
            "--resume",
            claude_session_id,
            "-p",
            "You were interrupted by a usage limit that has now reset. Continue the task exactly where you left off.",
        ]
    )
    return command


def run_headless_with_resume(
    command: list[str],
    argv: list[str],
    session_id: str,
    model: str,
    quota_key: str,
) -> int:
    """Run headless Claude; on limit-confirmed failure, wait for reset and resume."""
    claude_session_id = arg_value(argv, "--session-id")
    if not claude_session_id:
        claude_session_id = str(uuid.uuid4())
        command = [*command, "--session-id", claude_session_id]
    deadline = time.time() + wait_max_seconds()
    current = command
    for attempt in range(RESUME_MAX_ATTEMPTS + 1):
        result = subprocess.run(current)
        if result.returncode == 0:
            return 0
        # Only retry when the LB confirms the failure is account exhaustion
        # with a known reset; any other failure propagates immediately.
        claim, _, retry_at = claim_session_route(session_id, model, quota_key, AGENT_LB_BASE_URL)
        if claim is not None or not should_wait_for_reset(retry_at, deadline):
            return result.returncode
        if attempt == RESUME_MAX_ATTEMPTS:
            return result.returncode
        try:
            wait_until_reset(retry_at, "Claude run interrupted by account limits.")
        except KeyboardInterrupt:
            print("cc: aborted while waiting for limits to reset", file=sys.stderr)
            return 130
        print(f"cc: resuming session {claude_session_id} (attempt {attempt + 1})", file=sys.stderr)
        current = build_resume_command(argv, claude_session_id)
    return 1


def main() -> None:
    if len(sys.argv) >= 6 and sys.argv[1] == "--lb-proxy":
        run_lb_proxy(sys.argv[2], sys.argv[3], int(sys.argv[4]), sys.argv[5])
        return
    if len(sys.argv) >= 2 and sys.argv[1] == "--desktop-proxy":
        # Shared machine-wide proxy (run under launchd) for clients that can't
        # go through this launcher — the Claude desktop app wires to it via the
        # settings.json env block. Foreground, fixed port, no parent watchdog.
        listen_port = int(
            sys.argv[2] if len(sys.argv) >= 3 else os.environ.get("CLAUDE_LB_DESKTOP_PROXY_PORT", "2458")
        )
        upstream = (sys.argv[3] if len(sys.argv) >= 4 else AGENT_LB_BASE_URL).rstrip("/")
        run_lb_proxy(
            str(proxy_ready_path("desktop")),
            "",
            None,
            upstream,
            listen_port=listen_port,
            shared=True,
        )
        return

    argv = sys.argv[1:]
    routed = False
    session_id = ""
    if lb_enabled():
        session_id = derive_session_id(argv)
        if CCGPT_MODE:
            endpoint_ready = prepare_ccgpt_endpoint()
        elif headless_invocation(argv):
            endpoint_ready = print_lb_banner(argv, session_id)
        else:
            endpoint_ready = prepare_interactive_endpoint()
        if endpoint_ready:
            try:
                proxy_url = start_lb_proxy(session_id)
                # Keep Claude pointed at the real api.anthropic.com with its
                # keychain login (both are required for Remote Control), and route
                # its traffic through a local intercepting proxy instead. Claude's
                # undici global dispatcher CONNECT-tunnels every request through
                # HTTPS_PROXY; our proxy MITMs api.anthropic.com -> the LB (which
                # injects the pooled account's auth) and blind-tunnels everything
                # else (the RC bridge, telemetry, OAuth refresh) untouched.
                os.environ["HTTPS_PROXY"] = proxy_url
                os.environ["https_proxy"] = proxy_url
                # Trust the MITM leaf — scoped to this process only, never added to
                # the system trust store. Claude merges this with the bundled +
                # system roots, so every other host keeps validating normally.
                os.environ["NODE_EXTRA_CA_CERTS"] = str(CA_CERT)
                # Must NOT be set: a custom base URL fails RC's first-party check
                # (sCn); a unix socket or CLAUDE_CODE_OAUTH_TOKEN forces an
                # inference-only token and fails RC's full-scope check (vx). Clear
                # any leftovers from an earlier launcher version.
                os.environ.pop("ANTHROPIC_BASE_URL", None)
                os.environ.pop("ANTHROPIC_UNIX_SOCKET", None)
                os.environ.pop("_CLAUDE_CODE_ASSUME_FIRST_PARTY_BASE_URL", None)
                os.environ.pop("CLAUDE_CODE_OAUTH_TOKEN", None)
                # The LB injects the pooled account's auth; Claude's keychain OAuth
                # stays the active login (what RC needs). A local auth/api token
                # would flip Claude Code to API billing, so clear them.
                os.environ.pop("ANTHROPIC_AUTH_TOKEN", None)
                os.environ.pop("ANTHROPIC_API_KEY", None)
                routed = True
            except RuntimeError as error:
                print(f"cc: {error}", file=sys.stderr)
        if not routed:
            if CCGPT_MODE:
                print("ccgpt: refusing to bypass agent-lb or fall back to Claude", file=sys.stderr)
                sys.exit(1)
            print(
                "cc: falling back to plain claude (load balancer unavailable; using your normal Claude auth)",
                file=sys.stderr,
            )

    elif CCGPT_MODE:
        print("ccgpt: CLAUDE_LB_DISABLE is not allowed for this fail-closed command", file=sys.stderr)
        sys.exit(1)

    if not routed:
        bypass_anthropic_proxy()

    command = build_command(argv)
    if os.environ.get("CLAUDE_LB_DRY_RUN") == "1":
        print(" ".join(command))
        return
    if routed and not CCGPT_MODE and auto_resume_enabled() and headless_invocation(argv):
        model = requested_model(argv)
        quota_key, _ = anthropic_quota_key(model, requested_effort(argv))
        sys.exit(run_headless_with_resume(command, argv, session_id, model, quota_key))
    os.execvp(command[0], command)


if __name__ == "__main__":
    main()
