#!/usr/bin/env python3
from __future__ import annotations

import os
import shutil
import sys
from pathlib import Path


def main() -> None:
    if shutil.which("claude") is None:
        print("cc: Claude Code executable 'claude' was not found on PATH", file=sys.stderr)
        raise SystemExit(127)
    launcher = Path(__file__).resolve().with_name("claude-lb-launch")
    os.execv(launcher, [str(launcher), *sys.argv[1:]])


if __name__ == "__main__":
    main()
