SERVER_NAME = "ccdex-worker-mcp"
SERVER_VERSION = "1.0.0"
PROTOCOL_VERSION = "2025-06-18"
TERMINAL_STATES = {"succeeded", "failed", "timeout", "cancelled", "watchdog_killed"}
ACTIVE_STATES = {"queued", "running"}
RESULT_TEXT_LIMIT = 16_000
ERROR_TEXT_LIMIT = 4_000
DIFF_STAT_LIMIT = 4_000
MAX_LIST_LIMIT = 100
MAX_REQUEST_WORKERS = 16
FOREGROUND_WAIT_GRACE_S = 5.0
WATCHDOG_SIGNATURES = (
    "retrying request",
    "retry attempt",
    "will retry",
    "prompt is too long",
    "context_length_exceeded",
)
READ_ONLY_LIMITATION = (
    "Claude Code safe mode with only Read, Glob, and Grep tools; this is a harness restriction, "
    "not an operating-system filesystem sandbox"
)
SECRET_PATTERNS = (
    re.compile(r"\b(?:sk|ghp|github_pat|xox[baprs]|AKIA)[A-Za-z0-9_\-]{12,}\b"),
    re.compile(
        r"(?i)\b(api[_-]?key|access[_-]?token|auth[_-]?token|password|secret)\b"
        r"\s*[:=]\s*([^\s,;]+)"
    ),
    re.compile(r"(?i)\bBearer\s+[A-Za-z0-9._~+/=-]{8,}"),
)
JOB_ID_RE = re.compile(r"^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$")


class WorkerError(Exception):
    pass


def utc_now() -> str:
    return dt.datetime.now(dt.UTC).isoformat()


def worker_home() -> Path:
    configured = os.environ.get("CCDEX_WORKER_HOME")
    if configured:
        return Path(configured).expanduser().resolve()
    return Path("~/.agent-lb/ccdex-jobs").expanduser().resolve()


def metadata_path(job_dir: Path) -> Path:
    return job_dir / "metadata.json"


def redact(value: str) -> str:
    result = value
    for pattern in SECRET_PATTERNS:
        if pattern.groups == 2:
            result = pattern.sub(lambda match: f"{match.group(1)}=[REDACTED]", result)
        else:
            result = pattern.sub("[REDACTED]", result)
    return result


def bounded(value: str | None, limit: int) -> str | None:
    if value is None:
        return None
    clean = redact(value)
    if len(clean) <= limit:
        return clean
    omitted = len(clean) - limit
    return f"{clean[:limit]}\n...[truncated {omitted} characters]"


def atomic_write_json(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    descriptor, temporary_name = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    try:
        with os.fdopen(descriptor, "w", encoding="utf-8") as handle:
            json.dump(payload, handle, separators=(",", ":"), sort_keys=True)
            handle.write("\n")
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(temporary_name, path)
        directory_descriptor = os.open(path.parent, os.O_RDONLY)
        try:
            os.fsync(directory_descriptor)
        finally:
            os.close(directory_descriptor)
    finally:
        with contextlib.suppress(FileNotFoundError):
            os.unlink(temporary_name)


@contextlib.contextmanager
def metadata_lock(job_dir: Path) -> Iterator[None]:
    job_dir.mkdir(parents=True, exist_ok=True)
    with (job_dir / ".metadata.lock").open("a+", encoding="utf-8") as handle:
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(handle.fileno(), fcntl.LOCK_UN)


def read_metadata(job_dir: Path) -> dict[str, Any]:
    try:
        payload = json.loads(metadata_path(job_dir).read_text(encoding="utf-8"))
    except FileNotFoundError as error:
        raise WorkerError(f"unknown job: {job_dir.name}") from error
    except (OSError, json.JSONDecodeError) as error:
        raise WorkerError(f"job metadata is unreadable: {job_dir.name}") from error
    if not isinstance(payload, dict):
        raise WorkerError(f"job metadata is invalid: {job_dir.name}")
    return payload


def update_metadata(job_dir: Path, mutator: Callable[[dict[str, Any]], None]) -> dict[str, Any]:
    with metadata_lock(job_dir):
        payload = read_metadata(job_dir)
        before = json.dumps(payload, separators=(",", ":"), sort_keys=True)
        mutator(payload)
        if json.dumps(payload, separators=(",", ":"), sort_keys=True) == before:
            return payload
        payload["updated_at"] = utc_now()
        atomic_write_json(metadata_path(job_dir), payload)
        return payload


def process_alive(pid: object) -> bool:
    if not isinstance(pid, int) or pid <= 0:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def process_identity_state(pid: object, pgid: object) -> str:
    if pid is None and pgid is None:
        return "absent"
    if not isinstance(pid, int) or pid <= 0 or not isinstance(pgid, int) or pgid <= 0:
        return "mismatch"
    try:
        actual_pgid = os.getpgid(pid)
    except ProcessLookupError:
        return "absent"
    except PermissionError:
        return "mismatch"
    return "alive" if actual_pgid == pgid else "mismatch"


def worker_identity_state(payload: dict[str, Any]) -> str:
    worker_pid = payload.get("worker_pid")
    worker_pgid = payload.get("worker_pgid")
    if (
        isinstance(worker_pid, int)
        and worker_pid == payload.get("supervisor_pid")
        or isinstance(worker_pgid, int)
        and worker_pgid == payload.get("supervisor_pgid")
    ):
        return "mismatch"
    return process_identity_state(worker_pid, worker_pgid)


def require_job_id(value: object) -> str:
    if not isinstance(value, str) or not JOB_ID_RE.fullmatch(value):
        raise WorkerError("job_id must be a transport-issued UUID")
    return value


def job_dir_for(job_id: str) -> Path:
    return worker_home() / job_id


def resolve_worker_binary() -> str:
    configured = os.environ.get("CCDEX_WORKER_BIN")
    candidate = configured or str(Path(__file__).resolve().with_name("ccdex"))
    if os.path.sep in candidate:
        path = Path(candidate).expanduser().resolve()
        if not path.is_file() or not os.access(path, os.X_OK):
            raise WorkerError(f"CCDEX worker binary is missing or not executable: {path}")
        return str(path)
    resolved = shutil.which(candidate)
    if resolved is None:
        raise WorkerError(f"CCDEX worker binary was not found on PATH: {candidate}")
    return resolved


def preflight_worker(binary: str) -> None:
    try:
        result = subprocess.run(
            [binary, "--help"],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.PIPE,
            text=True,
            timeout=20,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired) as error:
        raise WorkerError(f"CCDEX worker preflight failed: {error}") from error
    if result.returncode != 0:
        detail = bounded(result.stderr.strip(), ERROR_TEXT_LIMIT) or "no error output"
        raise WorkerError(f"CCDEX worker preflight failed with exit {result.returncode}: {detail}")


def validate_string(arguments: dict[str, Any], name: str, *, required: bool = False) -> str | None:
    value = arguments.get(name)
    if value is None and not required:
        return None
    if not isinstance(value, str) or (required and not value.strip()):
        raise WorkerError(f"{name} must be a non-empty string")
    return value


def validate_bool(arguments: dict[str, Any], name: str, default: bool) -> bool:
    value = arguments.get(name, default)
    if not isinstance(value, bool):
        raise WorkerError(f"{name} must be a boolean")
    return value


def validate_timeout(arguments: dict[str, Any]) -> int:
    value = arguments.get("timeout_s", 1800)
    if isinstance(value, bool) or not isinstance(value, int) or not 1 <= value <= 86_400:
        raise WorkerError("timeout_s must be an integer between 1 and 86400")
    return value


def validate_cwd(value: object) -> Path:
    if not isinstance(value, str) or not value:
        raise WorkerError("cwd must be a non-empty absolute directory path")
    path = Path(value).expanduser()
    if not path.is_absolute():
        raise WorkerError("cwd must be absolute")
    path = path.resolve()
    if not path.is_dir():
        raise WorkerError(f"cwd is not a directory: {path}")
    return path


def git_output(cwd: Path, *arguments: str, timeout: int = 10) -> str:
    try:
        result = subprocess.run(
            ["git", "-C", str(cwd), *arguments],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=timeout,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired) as error:
        raise WorkerError(f"git command failed: {error}") from error
    if result.returncode != 0:
        detail = bounded(result.stderr.strip(), ERROR_TEXT_LIMIT) or "unknown git error"
        raise WorkerError(detail)
    return result.stdout.strip()


def create_worktree(cwd: Path, job_dir: Path, base_ref: str | None) -> tuple[Path, Path]:
    top_level_text = git_output(cwd, "rev-parse", "--show-toplevel")
    top_level = Path(top_level_text).resolve()
    try:
        relative_cwd = cwd.relative_to(top_level)
    except ValueError as error:
        raise WorkerError("cwd is not inside its reported git worktree") from error
    worktree = job_dir / "worktree"
    reference = base_ref or "HEAD"
    if reference.startswith("-"):
        raise WorkerError("base_ref must not begin with '-'")
    resolved_reference = git_output(
        top_level,
        "rev-parse",
        "--verify",
        "--end-of-options",
        f"{reference}^{{commit}}",
    )
    if not re.fullmatch(r"[0-9a-fA-F]{40,64}", resolved_reference):
        raise WorkerError("base_ref did not resolve to a commit")
    try:
        result = subprocess.run(
            ["git", "-C", str(top_level), "worktree", "add", "--detach", str(worktree), resolved_reference],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=60,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired) as error:
        raise WorkerError(f"worktree creation failed: {error}") from error
    if result.returncode != 0:
        detail = bounded(result.stderr.strip(), ERROR_TEXT_LIMIT) or "unknown git worktree error"
        raise WorkerError(f"worktree creation failed: {detail}")
    execution_cwd = (worktree / relative_cwd).resolve()
    if not execution_cwd.is_dir():
        raise WorkerError(f"worktree does not contain requested cwd: {relative_cwd}")
    return worktree, execution_cwd


def lock_path_for(realpath: Path) -> Path:
    digest = hashlib.sha256(str(realpath).encode()).hexdigest()
    return worker_home() / ".writer-locks" / f"{digest}.lock"


@contextlib.contextmanager
def writer_lock_guard(lock_path: Path) -> Iterator[None]:
    guard_path = lock_path.with_suffix(".guard")
    with guard_path.open("a+", encoding="utf-8") as handle:
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(handle.fileno(), fcntl.LOCK_UN)


def valid_writer_owner(owner: object) -> bool:
    return (
        isinstance(owner, dict)
        and isinstance(owner.get("job_id"), str)
        and JOB_ID_RE.fullmatch(owner["job_id"]) is not None
        and isinstance(owner.get("turn"), int)
        and not isinstance(owner["turn"], bool)
        and owner["turn"] >= 1
        and isinstance(owner.get("token"), str)
        and re.fullmatch(r"[0-9a-f]{32}", owner["token"]) is not None
        and isinstance(owner.get("realpath"), str)
        and bool(owner["realpath"])
    )


def read_writer_owner(lock_path: Path) -> dict[str, Any] | None:
    try:
        owner = json.loads(lock_path.read_text(encoding="utf-8"))
    except FileNotFoundError:
        return None
    except (OSError, json.JSONDecodeError):
        raise WorkerError(f"workspace already has an active writer: malformed lock owner at {lock_path}") from None
    if not valid_writer_owner(owner):
        raise WorkerError(f"workspace already has an active writer: malformed lock owner at {lock_path}")
    return owner


def create_writer_lockfile(lock_path: Path, owner: dict[str, Any]) -> None:
    descriptor = os.open(lock_path, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o600)
    try:
        encoded = (json.dumps(owner, separators=(",", ":"), sort_keys=True) + "\n").encode()
        offset = 0
        while offset < len(encoded):
            offset += os.write(descriptor, encoded[offset:])
        os.fsync(descriptor)
    except Exception:
        with contextlib.suppress(FileNotFoundError):
            lock_path.unlink()
        raise
    finally:
        os.close(descriptor)


def release_writer_lock(payload: dict[str, Any]) -> None:
    lock_text = payload.get("writer_lock")
    expected_owner = payload.get("writer_lock_owner")
    if not isinstance(lock_text, str) or not valid_writer_owner(expected_owner):
        return
    lock_path = Path(lock_text)
    with writer_lock_guard(lock_path):
        try:
            owner = read_writer_owner(lock_path)
        except WorkerError:
            return
        if owner != expected_owner:
            return
        with contextlib.suppress(FileNotFoundError):
            lock_path.unlink()


def acquire_writer_lock(realpath: Path, job_id: str, turn: int = 1) -> dict[str, Any]:
    lock_path = lock_path_for(realpath)
    lock_path.parent.mkdir(parents=True, exist_ok=True)
    owner = {"job_id": job_id, "turn": turn, "token": uuid.uuid4().hex, "realpath": str(realpath)}
    with writer_lock_guard(lock_path):
        for _ in range(2):
            try:
                create_writer_lockfile(lock_path, owner)
                return owner
            except FileExistsError:
                existing_owner = read_writer_owner(lock_path)
                if existing_owner is None:
                    continue
                try:
                    owner_metadata = recover_job(job_dir_for(existing_owner["job_id"]), release_lock=False)
                except WorkerError:
                    raise WorkerError(f"workspace already has an active writer: {realpath}") from None
                if (
                    owner_metadata.get("state") in TERMINAL_STATES
                    and owner_metadata.get("turn") == existing_owner["turn"]
                    and owner_metadata.get("writer_lock_owner") == existing_owner
                ):
                    lock_path.unlink()
                    continue
                raise WorkerError(f"workspace already has an active writer: {realpath}")
    raise WorkerError(f"could not acquire writer lock: {realpath}")


def base_metadata(
    job_id: str,
    prompt_path: Path,
    cwd: Path,
    execution_cwd: Path,
    mode: str,
    isolation: str,
    timeout_s: int,
    tag: str | None,
    allow_in_place: bool,
    worker_binary: str,
) -> dict[str, Any]:
    now = utc_now()
    return {
        "job_id": job_id,
        "state": "queued",
        "created_at": now,
        "updated_at": now,
        "started_at": None,
        "ended_at": None,
        "cwd": str(cwd),
        "execution_cwd": str(execution_cwd),
        "mode": mode,
        "isolation": isolation,
        "allow_in_place": allow_in_place,
        "timeout_s": timeout_s,
        "tag": tag,
        "worker_binary": worker_binary,
        "permission_boundary": READ_ONLY_LIMITATION if mode == "read-only" else "workspace write enabled",
        "prompt_path": str(prompt_path),
        "turn": 1,
        "turns": 0,
        "session_id": None,
        "supervisor_pid": None,
        "supervisor_pgid": None,
        "worker_pid": None,
        "worker_pgid": None,
        "exit_code": None,
        "usage": None,
        "final_text": None,
        "error": None,
        "cancel_requested": False,
        "duration_s": None,
        "total_duration_s": 0.0,
        "worktree_path": None,
        "worktree_owned": False,
        "writer_lock": None,
        "writer_lock_owner": None,
        "stdout_path": None,
        "stderr_path": None,
    }


def launch_supervisor(job_dir: Path) -> int:
    with (job_dir / "supervisor.log").open("ab", buffering=0) as supervisor_log:
        process = subprocess.Popen(
            [sys.executable, str(Path(__file__).resolve()), "--supervise", job_dir.name],
            stdin=subprocess.DEVNULL,
            stdout=supervisor_log,
            stderr=supervisor_log,
            start_new_session=True,
            close_fds=True,
        )
    update_metadata(
        job_dir,
        lambda payload: payload.update(supervisor_pid=process.pid, supervisor_pgid=process.pid),
    )
    return process.pid


def start_job(arguments: dict[str, Any]) -> dict[str, Any]:
    allowed = {
        "prompt",
        "cwd",
        "mode",
        "background",
        "isolation",
        "base_ref",
        "timeout_s",
        "tag",
        "allow_in_place",
    }
    unknown = sorted(set(arguments) - allowed)
    if unknown:
        raise WorkerError(f"unknown start input(s): {', '.join(unknown)}")
    prompt = validate_string(arguments, "prompt", required=True)
    assert prompt is not None
    cwd = validate_cwd(arguments.get("cwd"))
    mode = arguments.get("mode", "read-only")
    isolation = arguments.get("isolation", "none")
    if mode not in {"read-only", "workspace-write"}:
        raise WorkerError("mode must be read-only or workspace-write")
    if isolation not in {"none", "worktree"}:
        raise WorkerError("isolation must be none or worktree")
    background = validate_bool(arguments, "background", True)
    allow_in_place = validate_bool(arguments, "allow_in_place", False)
    timeout_s = validate_timeout(arguments)
    base_ref = validate_string(arguments, "base_ref")
    if base_ref is not None and base_ref.startswith("-"):
        raise WorkerError("base_ref must not begin with '-'")
    tag = validate_string(arguments, "tag")
    if tag is not None and len(tag) > 128:
        raise WorkerError("tag must be at most 128 characters")
    if mode == "workspace-write" and isolation == "none" and not allow_in_place:
        raise WorkerError("workspace-write requires isolation=worktree or allow_in_place=true")

    binary = resolve_worker_binary()
    preflight_worker(binary)
    home = worker_home()
    home.mkdir(parents=True, exist_ok=True)
    job_id = str(uuid.uuid4())
    job_dir = home / job_id
    job_dir.mkdir()
    prompt_path = job_dir / "turn-1.prompt"
    prompt_path.write_text(prompt, encoding="utf-8")
    execution_cwd = cwd
    payload = base_metadata(
        job_id,
        prompt_path,
        cwd,
        execution_cwd,
        mode,
        isolation,
        timeout_s,
        tag,
        allow_in_place,
        binary,
    )
    payload["supervisor_pid"] = os.getpid()
    payload["supervisor_pgid"] = os.getpgrp()
    atomic_write_json(metadata_path(job_dir), payload)
    try:
        if isolation == "worktree":
            worktree, execution_cwd = create_worktree(cwd, job_dir, base_ref)
            payload["worktree_path"] = str(worktree)
            payload["worktree_owned"] = True
            payload["execution_cwd"] = str(execution_cwd)
        if mode == "workspace-write":
            lock_owner = acquire_writer_lock(execution_cwd.resolve(), job_id, 1)
            payload["writer_lock"] = str(lock_path_for(execution_cwd.resolve()))
            payload["writer_lock_owner"] = lock_owner
        atomic_write_json(metadata_path(job_dir), payload)
        launch_supervisor(job_dir)
    except Exception as error:
        release_writer_lock(payload)
        payload["state"] = "failed"
        payload["error"] = bounded(str(error), ERROR_TEXT_LIMIT)
        payload["ended_at"] = utc_now()
        atomic_write_json(metadata_path(job_dir), payload)
        raise
    if not background:
        return wait_for_terminal(job_id, timeout_s)
    return public_status(recover_job(job_dir))


def reply_job(arguments: dict[str, Any]) -> dict[str, Any]:
    allowed = {"job_id", "prompt", "background", "timeout_s"}
    unknown = sorted(set(arguments) - allowed)
    if unknown:
        raise WorkerError(f"unknown reply input(s): {', '.join(unknown)}")
    job_id = require_job_id(arguments.get("job_id"))
    prompt = validate_string(arguments, "prompt", required=True)
    assert prompt is not None
    background = validate_bool(arguments, "background", True)
    timeout_override = arguments.get("timeout_s")
    if timeout_override is not None:
        validate_timeout(arguments)
    job_dir = job_dir_for(job_id)
    current = recover_job(job_dir)
    if current.get("state") not in TERMINAL_STATES:
        raise WorkerError("cannot reply while the job is active")
    if current.get("state") == "cancelled":
        raise WorkerError("cannot reply to a cancelled job")
    if not current.get("session_id"):
        raise WorkerError("cannot reply because no Claude session ID was captured")
    preflight_worker(str(current["worker_binary"]))
    turn = int(current.get("turn", 1)) + 1
    prompt_path = job_dir / f"turn-{turn}.prompt"
    prompt_path.write_text(prompt, encoding="utf-8")

    writer_lock: Path | None = None
    writer_lock_owner: dict[str, Any] | None = None
    if current.get("mode") == "workspace-write":
        execution_cwd = Path(str(current["execution_cwd"])).resolve()
        writer_lock_owner = acquire_writer_lock(execution_cwd, job_id, turn)
        writer_lock = lock_path_for(execution_cwd)

    def queue_reply(payload: dict[str, Any]) -> None:
        if payload.get("state") not in TERMINAL_STATES:
            raise WorkerError("cannot reply while the job is active")
        payload.update(
            state="queued",
            prompt_path=str(prompt_path),
            turn=turn,
            started_at=None,
            ended_at=None,
            supervisor_pid=os.getpid(),
            supervisor_pgid=os.getpgrp(),
            worker_pid=None,
            worker_pgid=None,
            exit_code=None,
            final_text=None,
            error=None,
            cancel_requested=False,
            duration_s=None,
            stdout_path=None,
            stderr_path=None,
            writer_lock=str(writer_lock) if writer_lock is not None else None,
            writer_lock_owner=writer_lock_owner,
        )
        if timeout_override is not None:
            payload["timeout_s"] = timeout_override

    try:
        update_metadata(job_dir, queue_reply)
        launch_supervisor(job_dir)
    except Exception:
        if writer_lock is not None:
            release_writer_lock(
                {"job_id": job_id, "writer_lock": str(writer_lock), "writer_lock_owner": writer_lock_owner}
            )
        raise
    if not background:
        return wait_for_terminal(job_id, int(timeout_override or current["timeout_s"]))
    return public_status(recover_job(job_dir))


def build_worker_command(payload: dict[str, Any]) -> list[str]:
    command = [
        str(payload["worker_binary"]),
        "--print",
        "--input-format",
        "text",
        "--output-format",
        "stream-json",
        "--verbose",
    ]
    if payload.get("mode") == "read-only":
        command.extend(["--safe-mode", "--permission-mode", "dontAsk", "--tools", "Read,Glob,Grep"])
    else:
        command.extend(["--permission-mode", "bypassPermissions"])
    if int(payload.get("turn", 1)) > 1:
        command.extend(["--resume", str(payload["session_id"])])
    return command


def pump_stream(name: str, stream: Any, events: queue.Queue[tuple[str, str | None]]) -> None:
    try:
        for line in iter(stream.readline, ""):
            events.put((name, line))
    finally:
        events.put((name, None))


def feed_stdin(stream: Any, prompt: str) -> None:
    try:
        stream.write(prompt)
        stream.flush()
    except (BrokenPipeError, OSError):
        pass
    finally:
        with contextlib.suppress(OSError):
            stream.close()


def parse_stream_event(payload: dict[str, Any], event: dict[str, Any]) -> None:
    session_id = event.get("session_id")
    if isinstance(session_id, str) and session_id:
        payload["session_id"] = session_id
    event_type = event.get("type")
    if event_type == "assistant":
        message = event.get("message")
        if isinstance(message, dict):
            content = message.get("content")
            if isinstance(content, list):
                text = "".join(
                    block.get("text", "")
                    for block in content
                    if isinstance(block, dict) and block.get("type") == "text"
                )
                if text:
                    payload["final_text"] = text
            usage = message.get("usage")
            if isinstance(usage, dict):
                payload["usage"] = usage
    elif event_type == "result":
        result_text = event.get("result")
        if isinstance(result_text, str):
            payload["final_text"] = result_text
        usage = event.get("usage")
        if isinstance(usage, dict):
            payload["usage"] = usage
        turns = event.get("num_turns")
        if isinstance(turns, int) and turns >= 0:
            payload["turns"] = int(payload.get("turns", 0)) + turns


def terminate_worker_identity(worker_pid: object, worker_pgid: object, grace_s: float = 3.0) -> bool:
    if process_identity_state(worker_pid, worker_pgid) != "alive":
        return False
    assert isinstance(worker_pid, int) and isinstance(worker_pgid, int)
    try:
        os.killpg(worker_pgid, signal.SIGTERM)
    except (ProcessLookupError, PermissionError):
        return False
    deadline = time.monotonic() + grace_s
    while time.monotonic() < deadline:
        if process_identity_state(worker_pid, worker_pgid) != "alive":
            return True
        time.sleep(0.05)
    if process_identity_state(worker_pid, worker_pgid) == "alive":
        with contextlib.suppress(ProcessLookupError, PermissionError):
            os.killpg(worker_pgid, signal.SIGKILL)
    return True


def finish_job(job_dir: Path, state: str, exit_code: int | None, error: str | None, started: float) -> None:
    elapsed = max(0.0, time.monotonic() - started)

    def finish(payload: dict[str, Any]) -> None:
        if payload.get("state") in TERMINAL_STATES and payload.get("duration_s") is not None:
            return
        if payload.get("state") not in TERMINAL_STATES:
            payload["state"] = state
            payload["exit_code"] = exit_code
            payload["error"] = bounded(error, ERROR_TEXT_LIMIT)
            payload["ended_at"] = utc_now()
        payload["duration_s"] = round(elapsed, 3)
        payload["total_duration_s"] = round(float(payload.get("total_duration_s", 0.0)) + elapsed, 3)

    final = update_metadata(job_dir, finish)
    release_writer_lock(final)


def supervise(job_id: str) -> int:
    job_id = require_job_id(job_id)
    job_dir = job_dir_for(job_id)
    initial = read_metadata(job_dir)
    prompt = Path(str(initial["prompt_path"])).read_text(encoding="utf-8")
    turn = int(initial.get("turn", 1))
    stdout_path = (job_dir / f"turn-{turn}.stdout.jsonl").resolve()
    stderr_path = (job_dir / f"turn-{turn}.stderr.log").resolve()
    command = build_worker_command(initial)
    environment = os.environ.copy()
    environment["CLAUDE_LB_SESSION_ID"] = job_id
    started = time.monotonic()
    try:
        with (
            stdout_path.open("w", encoding="utf-8") as stdout_log,
            stderr_path.open("w", encoding="utf-8") as stderr_log,
        ):
            process = subprocess.Popen(
                command,
                cwd=str(initial["execution_cwd"]),
                env=environment,
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
                bufsize=1,
                start_new_session=True,
            )
            pgid = os.getpgid(process.pid)

            def mark_running(payload: dict[str, Any]) -> None:
                if payload.get("state") in TERMINAL_STATES:
                    terminate_worker_identity(process.pid, pgid)
                    return
                payload.update(
                    state="running",
                    started_at=utc_now(),
                    supervisor_pid=os.getpid(),
                    supervisor_pgid=os.getpgrp(),
                    worker_pid=process.pid,
                    worker_pgid=pgid,
                    stdout_path=str(stdout_path),
                    stderr_path=str(stderr_path),
                )

            update_metadata(job_dir, mark_running)
            events: queue.Queue[tuple[str, str | None]] = queue.Queue()
            assert process.stdin is not None and process.stdout is not None and process.stderr is not None
            threads = [
                threading.Thread(target=pump_stream, args=("stdout", process.stdout, events), daemon=True),
                threading.Thread(target=pump_stream, args=("stderr", process.stderr, events), daemon=True),
            ]
            for thread in threads:
                thread.start()
            threading.Thread(target=feed_stdin, args=(process.stdin, prompt), daemon=True).start()
            closed_streams = 0
            watchdog_count = 0
            terminal_override: str | None = None
            while closed_streams < 2 or process.poll() is None:
                elapsed = time.monotonic() - started
                current = read_metadata(job_dir)
                if current.get("state") in TERMINAL_STATES:
                    terminal_override = str(current["state"])
                    terminate_worker_identity(process.pid, pgid)
                    break
                if current.get("cancel_requested"):
                    terminal_override = "cancelled"
                    terminate_worker_identity(process.pid, pgid)
                    break
                if elapsed >= int(current["timeout_s"]):
                    terminal_override = "timeout"
                    terminate_worker_identity(process.pid, pgid)
                    break
                try:
                    channel, line = events.get(timeout=0.1)
                except queue.Empty:
                    continue
                if line is None:
                    closed_streams += 1
                    continue
                target = stdout_log if channel == "stdout" else stderr_log
                target.write(line)
                target.flush()
                parsed_stdout = False
                if channel == "stdout":
                    try:
                        event = json.loads(line)
                    except json.JSONDecodeError:
                        event = None
                    else:
                        parsed_stdout = True
                    if isinstance(event, dict):
                        update_metadata(job_dir, lambda payload, item=event: parse_stream_event(payload, item))
                if channel == "stderr" or (channel == "stdout" and not parsed_stdout):
                    lowered = line.lower()
                    if any(signature in lowered for signature in WATCHDOG_SIGNATURES):
                        watchdog_count += 1
                        if watchdog_count >= 3:
                            terminal_override = "watchdog_killed"
                            terminate_worker_identity(process.pid, pgid)
                            break
            return_code = process.wait(timeout=5)
    except Exception as error:
        finish_job(job_dir, "failed", None, f"worker launch/supervision failed: {error}", started)
        return 1

    if terminal_override is not None:
        finish_job(job_dir, terminal_override, return_code, f"worker terminated: {terminal_override}", started)
    elif return_code == 0:
        finish_job(job_dir, "succeeded", return_code, None, started)
    else:
        finish_job(job_dir, "failed", return_code, f"worker exited with status {return_code}", started)
    return 0


def recover_job(job_dir: Path, *, release_lock: bool = True) -> dict[str, Any]:
    payload = read_metadata(job_dir)
    if payload.get("state") not in ACTIVE_STATES:
        return payload
    worker_state = worker_identity_state(payload)
    supervisor_state = process_identity_state(payload.get("supervisor_pid"), payload.get("supervisor_pgid"))
    if worker_state == "alive" or (worker_state == "absent" and supervisor_state == "alive"):
        return payload

    def recover(current: dict[str, Any]) -> None:
        current_worker_state = worker_identity_state(current)
        current_supervisor_state = process_identity_state(
            current.get("supervisor_pid"), current.get("supervisor_pgid")
        )
        if current.get("state") not in ACTIVE_STATES:
            return
        if current_worker_state == "mismatch":
            current["state"] = "failed"
            current["error"] = "orphan recovery: worker PID/PGID identity mismatch"
            current["ended_at"] = utc_now()
        elif current_worker_state != "alive" and current_supervisor_state == "mismatch":
            current["state"] = "failed"
            current["error"] = "orphan recovery: supervisor PID/PGID identity mismatch"
            current["ended_at"] = utc_now()
        elif current_worker_state != "alive" and current_supervisor_state != "alive":
            current["state"] = "failed"
            current["error"] = "orphan recovery: supervisor and worker processes are absent"
            current["ended_at"] = utc_now()

    recovered = update_metadata(job_dir, recover)
    if release_lock and recovered.get("state") == "failed":
        release_writer_lock(recovered)
    return recovered


def public_status(payload: dict[str, Any]) -> dict[str, Any]:
    return {
        "job_id": payload.get("job_id"),
        "state": payload.get("state"),
        "tag": payload.get("tag"),
        "mode": payload.get("mode"),
        "isolation": payload.get("isolation"),
        "created_at": payload.get("created_at"),
        "updated_at": payload.get("updated_at"),
        "started_at": payload.get("started_at"),
        "ended_at": payload.get("ended_at"),
        "session_id": payload.get("session_id"),
        "turns": payload.get("turns", 0),
        "duration_s": payload.get("duration_s"),
        "exit_code": payload.get("exit_code"),
        "error": bounded(payload.get("error"), ERROR_TEXT_LIMIT),
        "permission_boundary": payload.get("permission_boundary"),
    }


def safe_diff_stat(payload: dict[str, Any]) -> str | None:
    if payload.get("mode") != "workspace-write":
        return None
    cwd_text = payload.get("execution_cwd")
    if not isinstance(cwd_text, str):
        return None
    try:
        result = subprocess.run(
            ["git", "-C", cwd_text, "diff", "--stat", "--", "."],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=5,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None
    if result.returncode != 0:
        return None
    return bounded(result.stdout.strip(), DIFF_STAT_LIMIT)


def result_payload(payload: dict[str, Any]) -> dict[str, Any]:
    result = public_status(payload)
    result.update(
        final_text=bounded(payload.get("final_text"), RESULT_TEXT_LIMIT),
        usage=payload.get("usage") if isinstance(payload.get("usage"), dict) else None,
        total_duration_s=payload.get("total_duration_s"),
        diff_stat=safe_diff_stat(payload),
        stdout_path=str(Path(str(payload["stdout_path"])).resolve()) if payload.get("stdout_path") else None,
        stderr_path=str(Path(str(payload["stderr_path"])).resolve()) if payload.get("stderr_path") else None,
    )
    return result


def wait_for_terminal(job_id: str, timeout_s: int) -> dict[str, Any]:
    job_dir = job_dir_for(job_id)
    deadline = time.monotonic() + timeout_s + FOREGROUND_WAIT_GRACE_S
    while True:
        payload = recover_job(job_dir)
        if payload.get("state") in TERMINAL_STATES or time.monotonic() >= deadline:
            return result_payload(payload)
        time.sleep(0.1)


def status_job(arguments: dict[str, Any]) -> dict[str, Any]:
    if set(arguments) != {"job_id"}:
        raise WorkerError("ccdex_status requires only job_id")
    job_id = require_job_id(arguments.get("job_id"))
    return public_status(recover_job(job_dir_for(job_id)))


def get_result(arguments: dict[str, Any]) -> dict[str, Any]:
    allowed = {"job_id", "wait", "timeout_s"}
    unknown = sorted(set(arguments) - allowed)
    if unknown:
        raise WorkerError(f"unknown result input(s): {', '.join(unknown)}")
    job_id = require_job_id(arguments.get("job_id"))
    should_wait = validate_bool(arguments, "wait", False)
    wait_timeout = arguments.get("timeout_s", 30)
    if isinstance(wait_timeout, bool) or not isinstance(wait_timeout, int) or not 1 <= wait_timeout <= 3600:
        raise WorkerError("timeout_s must be an integer between 1 and 3600")
    deadline = time.monotonic() + wait_timeout
    while True:
        payload = recover_job(job_dir_for(job_id))
        if payload.get("state") in TERMINAL_STATES or not should_wait or time.monotonic() >= deadline:
            return result_payload(payload)
        time.sleep(0.1)


def cancel_job(arguments: dict[str, Any]) -> dict[str, Any]:
    if set(arguments) != {"job_id"}:
        raise WorkerError("ccdex_cancel requires only job_id")
    job_id = require_job_id(arguments.get("job_id"))
    job_dir = job_dir_for(job_id)
    payload = recover_job(job_dir)
    if payload.get("state") in TERMINAL_STATES:
        return public_status(payload)

    def request_cancel(current: dict[str, Any]) -> None:
        if current.get("state") in ACTIVE_STATES:
            current["cancel_requested"] = True

    payload = update_metadata(job_dir, request_cancel)
    identity_state = worker_identity_state(payload)
    if identity_state == "alive":
        terminate_worker_identity(payload.get("worker_pid"), payload.get("worker_pgid"))

    def mark_cancelled(current: dict[str, Any]) -> None:
        if current.get("state") in ACTIVE_STATES:
            if identity_state == "mismatch":
                current["state"] = "failed"
                current["error"] = "orphan recovery: worker PID/PGID identity mismatch"
            else:
                current["state"] = "cancelled"
                current["error"] = "worker terminated: cancelled"
            current["ended_at"] = utc_now()

    payload = update_metadata(job_dir, mark_cancelled)
    release_writer_lock(payload)
    return public_status(payload)


def list_jobs(arguments: dict[str, Any]) -> dict[str, Any]:
    allowed = {"limit", "tag"}
    unknown = sorted(set(arguments) - allowed)
    if unknown:
        raise WorkerError(f"unknown list input(s): {', '.join(unknown)}")
    limit = arguments.get("limit", 20)
    if isinstance(limit, bool) or not isinstance(limit, int) or not 1 <= limit <= MAX_LIST_LIMIT:
        raise WorkerError(f"limit must be an integer between 1 and {MAX_LIST_LIMIT}")
    tag = validate_string(arguments, "tag")
    home = worker_home()
    if not home.exists():
        return {"jobs": []}
    candidates: list[dict[str, Any]] = []
    for child in home.iterdir():
        if not child.is_dir() or not JOB_ID_RE.fullmatch(child.name):
            continue
        try:
            payload = recover_job(child)
        except WorkerError:
            continue
        if tag is None or payload.get("tag") == tag:
            candidates.append(payload)
    candidates.sort(key=lambda item: str(item.get("created_at", "")), reverse=True)
    return {"jobs": [public_status(item) for item in candidates[:limit]]}


