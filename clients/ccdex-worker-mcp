def rpc_result(request_id: object, result: dict[str, Any]) -> dict[str, Any]:
    return {"jsonrpc": "2.0", "id": request_id, "result": result}


def rpc_error(request_id: object, code: int, message: str) -> dict[str, Any]:
    return {"jsonrpc": "2.0", "id": request_id, "error": {"code": code, "message": bounded(message, ERROR_TEXT_LIMIT)}}


def tool_content(payload: dict[str, Any], *, is_error: bool = False) -> dict[str, Any]:
    return {
        "content": [{"type": "text", "text": json.dumps(payload, separators=(",", ":"), sort_keys=True)}],
        "isError": is_error,
    }


def handle_request(message: dict[str, Any]) -> dict[str, Any] | None:
    request_id = message.get("id")
    method = message.get("method")
    if not isinstance(method, str):
        return rpc_error(request_id, -32600, "invalid JSON-RPC request")
    if method.startswith("notifications/"):
        return None
    if method == "initialize":
        return rpc_result(
            request_id,
            {
                "protocolVersion": PROTOCOL_VERSION,
                "capabilities": {"tools": {"listChanged": False}},
                "serverInfo": {"name": SERVER_NAME, "version": SERVER_VERSION},
            },
        )
    if method == "ping":
        return rpc_result(request_id, {})
    if method == "tools/list":
        return rpc_result(request_id, {"tools": TOOL_SCHEMAS})
    if method != "tools/call":
        return rpc_error(request_id, -32601, f"unknown method: {method}")
    params = message.get("params")
    if not isinstance(params, dict):
        return rpc_error(request_id, -32602, "tools/call params must be an object")
    name = params.get("name")
    arguments = params.get("arguments", {})
    if not isinstance(name, str) or not isinstance(arguments, dict):
        return rpc_error(request_id, -32602, "tool name and object arguments are required")
    handler = TOOL_HANDLERS.get(name)
    if handler is None:
        return rpc_result(request_id, tool_content({"error": f"unknown tool: {name}"}, is_error=True))
    try:
        result = handler(arguments)
    except (WorkerError, OSError, ValueError, subprocess.SubprocessError) as error:
        return rpc_result(request_id, tool_content({"error": bounded(str(error), ERROR_TEXT_LIMIT)}, is_error=True))
    return rpc_result(request_id, tool_content(result))


class JsonRpcServer:
    def __init__(self) -> None:
        self.write_lock = threading.Lock()

    def write(self, response: dict[str, Any] | None) -> None:
        if response is None:
            return
        encoded = json.dumps(response, separators=(",", ":"), ensure_ascii=False)
        with self.write_lock:
            sys.stdout.write(encoded + "\n")
            sys.stdout.flush()

    def dispatch(self, message: dict[str, Any]) -> None:
        try:
            self.write(handle_request(message))
        except Exception as error:
            self.write(rpc_error(message.get("id"), -32603, f"internal error: {error}"))

    def run(self) -> None:
        with concurrent.futures.ThreadPoolExecutor(max_workers=MAX_REQUEST_WORKERS) as executor:
            for raw_line in sys.stdin:
                if not raw_line.strip():
                    continue
                try:
                    message = json.loads(raw_line)
                except json.JSONDecodeError as error:
                    self.write(rpc_error(None, -32700, f"parse error: {error.msg}"))
                    continue
                if not isinstance(message, dict):
                    self.write(rpc_error(None, -32600, "JSON-RPC message must be an object"))
                    continue
                executor.submit(self.dispatch, message)


def main() -> int:
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--supervise")
    arguments, unknown = parser.parse_known_args()
    if unknown:
        print(f"{SERVER_NAME}: unknown arguments: {' '.join(unknown)}", file=sys.stderr)
        return 2
    if arguments.supervise:
        return supervise(arguments.supervise)
    JsonRpcServer().run()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
