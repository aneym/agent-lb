{
  "version": "1.0",
  "skills": {
    "get-started": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Fresh-machine onboarding: install agent-lb, start the service, connect accounts, wire clients (GETTING-STARTED.md)",
      "promptTriggers": {
        "keywords": [
          "get started",
          "getting started",
          "set me up",
          "onboard",
          "onboarding",
          "install agent-lb",
          "set up agent-lb",
          "connect my accounts",
          "connect anthropic",
          "connect claude",
          "connect openai",
          "connect chatgpt",
          "anthropic oauth",
          "openai oauth",
          "claude code setup",
          "codex cli setup",
          "opencode setup",
          "openclaw setup",
          "wire claude code",
          "wire codex",
          "wire opencode",
          "wire openclaw",
          "wire sdk",
          "vercel ai sdk",
          "openai-compatible sdk",
          "anthropic-compatible sdk",
          "anthropic python sdk",
          "anthropic sdk",
          "claude sdk",
          "fresh install"
        ],
        "intentPatterns": [
          "(get|getting) started",
          "(set|setting) (me |.*)up",
          "(install|set ?up|onboard).*(agent-lb|load balancer|machine)",
          "(connect|add|import).*(account|claude|chatgpt|openai|anthropic)",
          "(wire|configure|set ?up|use).*(claude code|codex|opencode|openclaw|client|sdk|llm)",
          "(anthropic|openai).*(oauth|account|login|auth)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [],
        "pathExclusions": [],
        "contentPatterns": []
      }
    },
    "agent-lb-account-operator": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Account-specific agent-lb admin: dedicated browser profiles, billing actions, subscription ledger updates, pause/reactivate/remove, and account verification",
      "promptTriggers": {
        "keywords": [
          "account operator",
          "account profile",
          "account profiles",
          ".agent-lb/account-profiles",
          "browser profile",
          "subscription ledger",
          "subscription history",
          "billing action",
          "billing status",
          "quota reset",
          "account stuck",
          "rate limited account",
          "disabled account",
          "account status",
          "subscription status",
          "routing imbalance",
          "same account always picked",
          "reactivate routing",
          "pause routing",
          "pause account",
          "reactivate account",
          "remove account",
          "delete account",
          "verify account",
          "cancel subscription",
          "cancel account",
          "open account",
          "open chatgpt account",
          "open claude account"
        ],
        "intentPatterns": [
          "(add|connect|import|open|verify|remove|delete|pause|reactivate).*(account|profile|chatgpt|openai|anthropic|claude)",
          "(cancel|pause|reactivate|renew|upgrade|downgrade).*(subscription|billing|plan|account)",
          "(subscription|billing).*(ledger|history|status|profile|account)",
          "(quota|usage|reset|rate.?limit|disabled|stuck).*(account|dashboard|ledger|status)",
          "(same account|routing imbalance|always picked|load.?balanc).*(account|routing)",
          "(account|browser).*(profile|profiles)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [],
        "pathExclusions": [],
        "contentPatterns": []
      }
    },
    "codex-review-loop": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Automated adversarial PR code review loop powered by Codex CLI",
      "promptTriggers": {
        "keywords": [
          "codex review",
          "codex-review-loop",
          "adversarial review",
          "code review loop",
          "review PR",
          "pr review",
          "코드 리뷰",
          "리뷰 루프",
          "적대적 리뷰",
          "deep review"
        ],
        "intentPatterns": [
          "(review|check|audit).*(PR|pull request|branch|changes|code)",
          "(codex|adversarial).*(review|check|audit)",
          "(리뷰|검토|감사).*(PR|브랜치|변경|코드)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [],
        "pathExclusions": [],
        "contentPatterns": []
      }
    },
    "project-conventions": {
      "type": "domain",
      "enforcement": "remind",
      "priority": "high",
      "description": "Project code conventions (typing, structure, DI, testing, anti-patterns)",
      "promptTriggers": {
        "keywords": [
          "convention",
          "컨벤션",
          "code architecture",
          "코드 아키텍처",
          "coding standard"
        ],
        "intentPatterns": [
          "(implement|build|create|구현|생성).*(module|feature|모듈|기능)",
          "(convention|컨벤션|architecture|아키텍처).*(guide|reference|참조)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "**/app/modules/**/*.py",
          "**/app/core/**/*.py",
          "**/app/db/**/*.py",
          "**/app/dependencies.py",
          "**/app/main.py",
          "**/tests/**/*.py"
        ],
        "pathExclusions": ["**/__pycache__/**"]
      },
      "skipConditions": {
        "sessionSkillUsed": true,
        "envOverride": "SKIP_CONVENTION_GUARD"
      },
      "blockMessage": "BLOCKED: Run /project-conventions first.\nYou must review project conventions before editing code.\n\n→ Skill tool: 'project-conventions'\n→ Bypass: SKIP_CONVENTION_GUARD=1"
    }
  }
}
