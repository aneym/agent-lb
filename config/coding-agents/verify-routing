#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path

HOME = Path(os.environ.get("AGENT_LB_USER_HOME", Path.home()))
REPO = Path(__file__).resolve().parents[2]
CANONICAL = HOME / ".agents" / "policy" / "coding-agents" / "ROUTING.md"
MARKER = "<!-- agent-lb:coding-agent-routing:start -->"
failures: list[str] = []


def check(condition: bool, message: str) -> None:
    if condition:
        print(f"PASS {message}")
    else:
        failures.append(message)
        print(f"FAIL {message}")


check(CANONICAL.is_file(), f"canonical policy exists at {CANONICAL}")

claude_doc = HOME / ".claude" / "CLAUDE.md"
claude_text = claude_doc.read_text() if claude_doc.is_file() else ""
check(claude_text.count(MARKER) == 1, f"{claude_doc} has one managed routing block")
check(
    claude_text.count("~/.agents/policy/coding-agents/ROUTING.md") == 1,
    f"{claude_doc} points once to canonical policy",
)

codex_doc = HOME / ".codex" / "AGENTS.md"
codex_text = codex_doc.read_text() if codex_doc.is_file() else ""
check(MARKER not in codex_text, f"{codex_doc} carries no retired managed routing block")

settings_path = HOME / ".claude" / "settings.json"
try:
    settings = json.loads(settings_path.read_text()) if settings_path.is_file() else {}
except json.JSONDecodeError:
    settings = {}
    check(False, f"{settings_path} contains valid JSON")
check(settings.get("model") == "claude-fable-5", "direct Claude Code default is Fable")

designer_source = REPO / "config" / "coding-agents" / "agents" / "frontend-designer.md"
designer_path = HOME / ".claude" / "agents" / "frontend-designer.md"
designer_owner_path = HOME / ".agent-lb" / "managed" / "coding-agents" / "frontend-designer"
designer_source_text = designer_source.read_text() if designer_source.is_file() else ""
designer_text = designer_path.read_text() if designer_path.is_file() else ""
check(designer_source.is_file(), f"canonical frontend designer exists at {designer_source}")
check("\nmodel: opus\n" in designer_source_text, "canonical frontend designer selects Opus")
check(
    designer_path.is_file() and designer_text == designer_source_text,
    f"{designer_path} matches the canonical Opus designer definition",
)
check(
    designer_owner_path.is_file()
    and designer_owner_path.read_text() == "agent-lb:frontend-designer:v1\n",
    f"{designer_owner_path} records installer ownership",
)

owned_registrations = [
    (event, group.get("matcher", ""))
    for event, groups in settings.get("hooks", {}).items()
    for group in groups
    for hook_config in group.get("hooks", [])
    if "ccdex-gpt-only.sh" in hook_config.get("command", "")
]
check(not owned_registrations, "no retired CCDEX hook registrations remain in settings")
check(not (HOME / ".claude" / "hooks" / "ccdex-gpt-only.sh").exists(), "retired CCDEX hook file is absent")

pytest_bin = REPO / ".venv" / "bin" / "pytest"
if pytest_bin.is_file():
    launcher_test = subprocess.run(
        [
            str(pytest_bin),
            "-q",
            "tests/unit/test_claude_lb_launch.py",
            "tests/unit/test_install_claude_clients.py",
        ],
        cwd=REPO,
        text=True,
        capture_output=True,
        timeout=120,
    )
    check(launcher_test.returncode == 0, "launcher and installer routing tests pass")
    if launcher_test.returncode:
        print(launcher_test.stdout[-2000:])
        print(launcher_test.stderr[-2000:], file=sys.stderr)
else:
    check(False, f"routing test runner exists at {pytest_bin}")

bin_dir = HOME / ".local" / "bin"
cc_target = bin_dir / "cc"
check(
    cc_target.is_symlink() and cc_target.resolve() == (REPO / "clients" / "cc").resolve(),
    "cc resolves to the repository client",
)
for name in ("ccdex", "ccdex-worker-mcp"):
    check(not (bin_dir / name).exists(), f"retired client {name} is absent from {bin_dir}")

policy_link = HOME / ".agents" / "policy" / "coding-agents"
check(
    policy_link.is_symlink() and policy_link.resolve() == (REPO / "config" / "coding-agents").resolve(),
    "policy link resolves to the repository policy",
)

claude_bin = os.environ.get("AGENT_LB_CLAUDE_BIN")
if not claude_bin:
    local_claude = HOME / ".local" / "bin" / "claude"
    claude_bin = str(local_claude) if local_claude.is_file() else "claude"
try:
    mcp = subprocess.run(
        [claude_bin, "mcp", "get", "ccdex-worker"],
        text=True,
        capture_output=True,
        timeout=30,
    )
except FileNotFoundError:
    check(False, f"Claude Code executable exists at {claude_bin}")
else:
    check(mcp.returncode != 0, "retired ccdex-worker MCP is not registered")

if failures:
    print(f"\n{len(failures)} routing check(s) failed", file=sys.stderr)
    raise SystemExit(1)
print("\nAll deterministic coding-agent routing checks passed.")
